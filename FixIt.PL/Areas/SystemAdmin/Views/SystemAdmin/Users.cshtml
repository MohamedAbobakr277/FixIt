@model IEnumerable<FixIt.BLL.DTOs.UserManagementDto>
@{
    ViewData["Title"] = "Manage Users";
}

<!-- Page Header -->
<div class="sa-page-header">
    <h1 class="sa-page-title">User <span>Management</span></h1>
    <p class="sa-page-subtitle">Manage roles, access, and permissions for all platform users.</p>
</div>

@if (TempData["ErrorMessage"] != null)
{
    <div class="sa-alert sa-alert-danger">⚠ @TempData["ErrorMessage"]</div>
}
@if (TempData["SuccessMessage"] != null)
{
    <div class="sa-alert sa-alert-success">✓ @TempData["SuccessMessage"]</div>
}

<!-- Search & Filter Bar -->
<form method="get" asp-action="Users" class="sa-search-bar">
    <input type="text" name="searchTerm" value="@ViewData["CurrentSearch"]" placeholder="Search by name or email..." class="sa-search-input" />
    <select name="roleFilter" class="sa-search-select">
        <option value="">All Roles</option>
        @if ((ViewData["CurrentRole"] as string) == "Citizen") { <option value="Citizen" selected>Citizen</option> } else { <option value="Citizen">Citizen</option> }
        @if ((ViewData["CurrentRole"] as string) == "Admin") { <option value="Admin" selected>Admin</option> } else { <option value="Admin">Admin</option> }
        @if ((ViewData["CurrentRole"] as string) == "SystemAdmin") { <option value="SystemAdmin" selected>System Admin</option> } else { <option value="SystemAdmin">System Admin</option> }
    </select>
    <button type="submit" class="sa-btn sa-btn-primary">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round"><circle cx="11" cy="11" r="8"/><line x1="21" y1="21" x2="16.65" y2="16.65"/></svg>
        Search
    </button>
    <a asp-action="Users" class="sa-btn sa-btn-secondary">Clear</a>
    <a asp-action="ExportUsers" class="sa-btn sa-btn-success" style="margin-left: auto;">
        <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M21 15v4a2 2 0 0 1-2 2H5a2 2 0 0 1-2-2v-4"/><polyline points="7 10 12 15 17 10"/><line x1="12" y1="15" x2="12" y2="3"/></svg>
        Export CSV
    </a>
</form>

<!-- Users Table -->
<div class="sa-card">
    <div class="sa-card-header">
        <div class="sa-card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M17 21v-2a4 4 0 0 0-4-4H5a4 4 0 0 0-4 4v2"/><circle cx="9" cy="7" r="4"/><path d="M23 21v-2a4 4 0 0 0-3-3.87"/><path d="M16 3.13a4 4 0 0 1 0 7.75"/></svg>
            Registered Users
        </div>
        <span style="font-size: 12px; color: var(--sa-text-muted); font-weight: 500;">@Model.Count() total</span>
    </div>

    @if (!Model.Any())
    {
        <div class="sa-empty">
            <div class="sa-empty-icon">🔍</div>
            <div class="sa-empty-text">No users found matching your criteria.</div>
        </div>
    }
    else
    {
        <table class="sa-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>Role</th>
                    <th>Status</th>
                    <th>Joined</th>
                    <th style="text-align: right;">Actions</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var user in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="sa-user-avatar">
                                    @(string.IsNullOrEmpty(user.FullName) ? "U" : user.FullName[0].ToString().ToUpper())
                                </div>
                                <div>
                                    <div style="font-weight: 600; font-size: 13.5px; margin-bottom: 2px;">@user.FullName</div>
                                    <div class="sa-user-id">@user.Id.Substring(0, 8)…</div>
                                </div>
                            </div>
                        </td>
                        <td style="color: var(--sa-text-secondary);">@user.Email</td>
                        <td>
                            @if (user.Role == "SystemAdmin")
                            {
                                <span class="sa-badge sa-badge-sysadmin">System Admin</span>
                            }
                            else if (user.Role == "Admin")
                            {
                                <span class="sa-badge sa-badge-admin">Admin</span>
                            }
                            else
                            {
                                <span class="sa-badge sa-badge-citizen">Citizen</span>
                            }
                        </td>
                        <td>
                            @if (user.IsLockedOut)
                            {
                                <span class="sa-badge sa-badge-locked">🔒 Locked</span>
                            }
                            else
                            {
                                <span class="sa-badge sa-badge-active">● Active</span>
                            }
                        </td>
                        <td style="color: var(--sa-text-secondary); font-size: 13px;">
                            @user.CreatedAt.ToString("MMM dd, yyyy")
                        </td>
                        <td style="text-align: right;">
                            <div class="dropdown">
                                <button class="sa-manage-btn dropdown-toggle" type="button" data-bs-toggle="dropdown" aria-expanded="false">
                                    Manage
                                </button>
                                <ul class="dropdown-menu dropdown-menu-end sa-dropdown-menu">
                                    <li><h6 class="dropdown-header">Change Role</h6></li>
                                    <form asp-action="ChangeRole" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="newRole" value="Citizen" />
                                        <li><button type="submit" class="dropdown-item" style="@(user.Role == "Citizen" ? "opacity: 0.4;" : "")" @(user.Role == "Citizen" ? "disabled" : "")>👤 Make Citizen</button></li>
                                    </form>
                                    <form asp-action="ChangeRole" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="newRole" value="Admin" />
                                        <li><button type="submit" class="dropdown-item" style="@(user.Role == "Admin" ? "opacity: 0.4;" : "")" @(user.Role == "Admin" ? "disabled" : "")>🛡️ Make Admin</button></li>
                                    </form>
                                    <form asp-action="ChangeRole" method="post" class="d-inline">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <input type="hidden" name="newRole" value="SystemAdmin" />
                                        <li><button type="submit" class="dropdown-item" style="@(user.Role == "SystemAdmin" ? "opacity: 0.4;" : "")" @(user.Role == "SystemAdmin" ? "disabled" : "")>💻 Make System Admin</button></li>
                                    </form>
                                    <li><hr class="dropdown-divider"></li>
                                    <li><h6 class="dropdown-header">Access Control</h6></li>
                                    <form asp-action="ToggleLock" method="post">
                                        <input type="hidden" name="userId" value="@user.Id" />
                                        <li>
                                            @if (user.IsLockedOut)
                                            {
                                                <button type="submit" class="dropdown-item text-success">🔓 Unlock Account</button>
                                            }
                                            else
                                            {
                                                <button type="submit" class="dropdown-item text-danger">🔒 Lock Account</button>
                                            }
                                        </li>
                                    </form>
                                </ul>
                            </div>
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
