@model IEnumerable<FixIt.BLL.DTOs.SystemLogDto>
@{
    ViewData["Title"] = "Audit Logs";
}

<!-- Page Header -->
<div class="sa-page-header">
    <h1 class="sa-page-title">System <span>Audit Logs</span></h1>
    <p class="sa-page-subtitle">Monitor platform-wide authentication events and access history.</p>
</div>

<!-- Logs Table -->
<div class="sa-card">
    <div class="sa-card-header">
        <div class="sa-card-title">
            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
            Global Login History
        </div>
        <span style="font-size: 12px; color: var(--sa-text-muted); font-weight: 500;">Last 100 events</span>
    </div>

    @if (!Model.Any())
    {
        <div class="sa-empty">
            <div class="sa-empty-icon">🔍</div>
            <div class="sa-empty-text">No audit logs available.</div>
        </div>
    }
    else
    {
        <table class="sa-table">
            <thead>
                <tr>
                    <th>User</th>
                    <th>Email</th>
                    <th>IP Address</th>
                    <th>Device</th>
                    <th>Status</th>
                    <th style="text-align: right;">Timestamp</th>
                </tr>
            </thead>
            <tbody>
                @foreach (var log in Model)
                {
                    <tr>
                        <td>
                            <div style="display: flex; align-items: center; gap: 12px;">
                                <div class="sa-user-avatar" style="@(log.IsSuccess ? "" : "background: linear-gradient(135deg, #ef4444, #dc2626);")">
                                    @(string.IsNullOrEmpty(log.FullName) || log.FullName == "Unknown" ? "?" : log.FullName[0].ToString().ToUpper())
                                </div>
                                <div>
                                    <div style="font-weight: 600; font-size: 13.5px;">@log.FullName</div>
                                </div>
                            </div>
                        </td>
                        <td style="color: var(--sa-text-secondary);">@log.UserEmail</td>
                        <td>
                            <span style="font-family: var(--sa-font-mono); font-size: 12px; color: var(--sa-text-secondary); background: rgba(255,255,255,0.04); padding: 3px 8px; border-radius: 4px;">@log.IpAddress</span>
                        </td>
                        <td style="color: var(--sa-text-secondary); font-size: 13px; max-width: 200px; overflow: hidden; text-overflow: ellipsis; white-space: nowrap;">
                            @(string.IsNullOrEmpty(log.Device) ? "Unknown Device" : log.Device)
                        </td>
                        <td>
                            @if (log.IsSuccess)
                            {
                                <span class="sa-badge sa-badge-success">● Success</span>
                            }
                            else
                            {
                                <span class="sa-badge sa-badge-failed">✕ Failed</span>
                            }
                        </td>
                        <td style="text-align: right; font-family: var(--sa-font-mono); font-size: 12px; color: var(--sa-text-secondary);">
                            @log.LoginTime.ToLocalTime().ToString("MMM dd, HH:mm:ss")
                        </td>
                    </tr>
                }
            </tbody>
        </table>
    }
</div>
