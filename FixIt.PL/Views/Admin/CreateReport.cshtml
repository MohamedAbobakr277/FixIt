@using FixIt.BLL.DTOs
@model CreateReportDto

@{
    ViewData["Title"] = "Create Report";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-8">
            <div class="card">
                <div class="card-header bg-success text-white">
                    <h5><i class="bi bi-clipboard-check"></i> Completion Report</h5>
                </div>
                <div class="card-body">
                    <form asp-action="SubmitReport" method="post" enctype="multipart/form-data">
                        <input type="hidden" asp-for="IssueId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="Summary" class="form-label"></label>
                            <textarea asp-for="Summary" class="form-control" rows="4" 
                                      placeholder="Provide a summary of work completed..."></textarea>
                            <span asp-validation-for="Summary" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="WorkerNotes" class="form-label"></label>
                            <textarea asp-for="WorkerNotes" class="form-control" rows="3" 
                                      placeholder="Additional notes from worker..."></textarea>
                            <span asp-validation-for="WorkerNotes" class="text-danger"></span>
                        </div>

                        <div class="row">
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="BeforeImage" class="form-label"></label>
                                    <input asp-for="BeforeImage" class="form-control" type="file" 
                                           accept="image/*" />
                                    <span asp-validation-for="BeforeImage" class="text-danger"></span>
                                </div>
                            </div>
                            <div class="col-md-6">
                                <div class="mb-3">
                                    <label asp-for="AfterImage" class="form-label"></label>
                                    <input asp-for="AfterImage" class="form-control" type="file" 
                                           accept="image/*" />
                                    <span asp-validation-for="AfterImage" class="text-danger"></span>
                                </div>
                            </div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-success">
                                <i class="bi bi-check-circle"></i> Submit Report
                            </button>
                            <a asp-action="Reports" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Reports
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
