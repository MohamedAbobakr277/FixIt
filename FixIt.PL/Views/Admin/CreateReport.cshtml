@using FixIt.BLL.DTOs
@model CreateReportDto

@{
    ViewData["Title"] = "Create Report";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";
}

@section Styles {
<style>
    .rep-card {
        background: var(--adm-surface);
        border-radius: var(--adm-radius-lg);
        box-shadow: 0 4px 20px rgba(0, 0, 0, 0.04);
        padding: 32px;
        max-width: 900px;
        margin: 20px auto;
        border: 1px solid var(--adm-border);
    }
    .rep-card-header {
        margin-bottom: 24px;
    }
    .rep-card-title {
        font-size: 18px;
        font-weight: 700;
        color: var(--adm-text);
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 0 0 6px 0;
    }
    .rep-card-subtitle {
        font-size: 13px;
        color: var(--adm-muted);
        margin: 0;
    }

    .rep-issue-summary-box {
        background: rgba(0, 151, 167, 0.1);
        border-radius: 8px;
        padding: 16px 20px;
        margin-bottom: 24px;
        border: 1px solid rgba(0, 151, 167, 0.15);
    }
    .rep-summary-title {
        font-size: 15px;
        font-weight: 700;
        color: var(--adm-primary);
        margin-bottom: 8px;
    }
    .rep-summary-meta {
        font-size: 12.5px;
        color: var(--adm-text);
        display: flex;
        gap: 16px;
    }
    .rep-summary-meta i {
        color: var(--adm-muted);
    }

    .rep-group {
        margin-bottom: 24px;
    }
    .rep-label {
        display: block;
        font-size: 13px;
        font-weight: 700;
        color: var(--adm-text);
        margin-bottom: 8px;
    }
    .rep-input, .rep-textarea {
        width: 100%;
        padding: 12px 14px;
        border: 1px solid var(--adm-border);
        border-radius: 8px;
        background: #f8fafc;
        color: var(--adm-text);
        font-size: 14px;
        font-family: var(--adm-font);
        outline: none;
        transition: border-color 0.2s;
    }
    [data-adm-theme="dark"] .rep-input, [data-adm-theme="dark"] .rep-textarea {
        background: var(--adm-bg);
    }
    .rep-textarea {
        resize: vertical;
        min-height: 100px;
    }
    .rep-input:focus, .rep-textarea:focus {
        border-color: var(--adm-primary);
    }
    .rep-file-control {
        display: block;
        width: 100%;
        padding: 8px 12px;
        font-size: 13px;
        color: var(--adm-text);
        background-color: #f8fafc;
        background-clip: padding-box;
        border: 1px solid var(--adm-border);
        border-radius: 6px;
    }
    [data-adm-theme="dark"] .rep-file-control { background: var(--adm-bg); }

    .rep-submit-btn {
        width: 100%;
        padding: 14px;
        background: var(--adm-primary);
        color: #fff;
        border: none;
        border-radius: 8px;
        font-size: 15px;
        font-weight: 700;
        cursor: pointer;
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 8px;
        transition: all 0.2s;
    }
    .rep-submit-btn:hover {
        background: #0097a7; /* slightly darker cyan */
    }

    .text-danger {
        color: #ef4444;
        font-size: 12.5px;
        margin-top: 6px;
        display: block;
    }
    .rep-grid-2 {
        display: grid;
        grid-template-columns: 1fr 1fr;
        gap: 20px;
    }
    @@media (max-width: 600px) {
        .rep-grid-2 { grid-template-columns: 1fr; }
    }
</style>
}

<div class="rep-card">
    <div class="rep-card-header">
        <h2 class="rep-card-title">
            <svg width="20" height="20" viewBox="0 0 24 24" fill="var(--adm-primary)" stroke="none">
                <path d="M19 3H5c-1.1 0-2 .9-2 2v14c0 1.1.9 2 2 2h14c1.1 0 2-.9 2-2V5c0-1.1-.9-2-2-2zm-9 14l-5-5 1.41-1.41L10 14.17l7.59-7.59L19 8l-9 9z"/>
            </svg>
            Completion Report
        </h2>
        <p class="rep-card-subtitle">Submit a completion report for this issue</p>
    </div>

    <form asp-action="SubmitReport" method="post" enctype="multipart/form-data">
        <input type="hidden" asp-for="IssueId" />
        
        <div asp-validation-summary="ModelOnly" class="text-danger" style="margin-bottom: 20px;"></div>

        <div class="rep-issue-summary-box">
            <div class="rep-summary-title">Issue #@Model.IssueId</div>
            <div class="rep-summary-meta">
                <span>Please fill out the final details below to mark this issue as resolved.</span>
            </div>
        </div>

        <div class="rep-group">
            <label asp-for="Summary" class="rep-label">Report Summary *</label>
            <textarea asp-for="Summary" class="rep-textarea" minlength="10" required
                      placeholder="Provide a detailed summary of the work completed..."></textarea>
            <span asp-validation-for="Summary" class="text-danger"></span>
        </div>

        <div class="rep-group">
            <label asp-for="WorkerNotes" class="rep-label">Worker Notes</label>
            <textarea asp-for="WorkerNotes" class="rep-textarea" 
                      placeholder="Any additional notes or comments from the worker..."></textarea>
            <span asp-validation-for="WorkerNotes" class="text-danger"></span>
        </div>

        <div class="rep-grid-2">
            <div class="rep-group">
                <label asp-for="BeforeImage" class="rep-label">Before Image</label>
                <input asp-for="BeforeImage" class="rep-file-control" type="file" accept="image/*" />
                <span asp-validation-for="BeforeImage" class="text-danger"></span>
            </div>
            <div class="rep-group">
                <label asp-for="AfterImage" class="rep-label">After Image</label>
                <input asp-for="AfterImage" class="rep-file-control" type="file" accept="image/*" />
                <span asp-validation-for="AfterImage" class="text-danger"></span>
            </div>
        </div>

        <div style="margin-top: 32px;">
            <button type="submit" class="rep-submit-btn">
                <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path>
                    <polyline points="22 4 12 14.01 9 11.01"></polyline>
                </svg>
                Mark as Resolved
            </button>
        </div>
    </form>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
