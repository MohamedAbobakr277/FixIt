@using FixIt.BLL.DTOs
@model SchedulePageDto

@{
    ViewData["Title"] = "Maintenance Schedule";
}

<div class="container mt-4">
    <div class="row mb-4">
        <div class="col-md-6">
            <div class="card bg-primary text-white">
                <div class="card-body">
                    <h5 class="card-title">Scheduled</h5>
                    <h2 class="display-4">@Model.ScheduledCount</h2>
                </div>
            </div>
        </div>
        <div class="col-md-6">
            <div class="card bg-warning text-dark">
                <div class="card-body">
                    <h5 class="card-title">In Progress</h5>
                    <h2 class="display-4">@Model.InProgressCount</h2>
                </div>
            </div>
        </div>
    </div>

    @if (Model.InProgressItems.Any())
    {
        <div class="card mb-4">
            <div class="card-header bg-warning text-dark">
                <h5><i class="bi bi-tools"></i> Currently In Progress</h5>
            </div>
            <div class="card-body">
                <div class="row">
                    @foreach (var item in Model.InProgressItems)
                    {
                        <div class="col-md-6 col-lg-4 mb-3">
                            <div class="card h-100">
                                <div class="card-body">
                                    <h6 class="card-title">@item.IssueTitle</h6>
                                    <p class="card-text">
                                        <small class="text-muted">
                                            <i class="bi bi-geo-alt"></i> @item.Location<br />
                                            <i class="bi bi-person"></i> @(item.WorkerName ?? "Not assigned")
                                        </small>
                                    </p>
                                    <span class="badge bg-warning text-dark">@item.Status</span>
                                </div>
                                <div class="card-footer">
                                    <a href="/Issue/Details/@item.IssueId" class="btn btn-sm btn-outline-primary">
                                        <i class="bi bi-eye"></i> View
                                    </a>
                                </div>
                            </div>
                        </div>
                    }
                </div>
            </div>
        </div>
    }

    @if (Model.UpcomingItems.Any())
    {
        <div class="card">
            <div class="card-header bg-primary text-white">
                <h5><i class="bi bi-calendar"></i> Scheduled Maintenance</h5>
            </div>
            <div class="card-body">
                @foreach (var group in Model.UpcomingItems.GroupBy(x => x.VisitDate.Date).OrderBy(x => x.Key))
                {
                    <div class="mb-4">
                        <h6 class="text-primary mb-3">
                            <i class="bi bi-calendar-day"></i> @group.Key.ToString("MMMM dd, yyyy")
                        </h6>
                        <div class="table-responsive">
                            <table class="table table-hover">
                                <thead>
                                    <tr>
                                        <th>Category</th>
                                        <th>Title</th>
                                        <th>Time</th>
                                        <th>Worker</th>
                                        <th>Cost</th>
                                        <th>Action</th>
                                    </tr>
                                </thead>
                                <tbody>
                                    @foreach (var item in group.OrderBy(x => x.VisitDate))
                                    {
                                        <tr>
                                            <td>
                                                <i class="bi bi-@GetCategoryIcon(item.Category)"></i>
                                                @item.Category
                                            </td>
                                            <td>@item.IssueTitle</td>
                                            <td>@item.VisitDate.ToString("h:mm tt")</td>
                                            <td>@(item.WorkerName ?? "Not assigned")</td>
                                            <td>@item.EstimatedCost.ToString("C")</td>
                                            <td>
                                                <a href="/Issue/Details/@item.IssueId" class="btn btn-sm btn-outline-primary">
                                                    <i class="bi bi-eye"></i>
                                                </a>
                                            </td>
                                        </tr>
                                    }
                                </tbody>
                            </table>
                        </div>
                    </div>
                }
            </div>
        </div>
    }

    @if (!Model.InProgressItems.Any() && !Model.UpcomingItems.Any())
    {
        <div class="text-center py-5">
            <i class="bi bi-calendar-x text-muted" style="font-size: 3rem;"></i>
            <h4 class="text-muted mt-3">No maintenance scheduled</h4>
            <p class="text-muted">Approved issues will appear here once scheduled.</p>
        </div>
    }
</div>

@functions {
    public string GetCategoryIcon(string category)
    {
        return category.ToLower() switch
        {
            "plumbing" => "droplet",
            "electrical" => "lightning",
            "hvac" => "thermometer-half",
            "carpentry" => "hammer",
            "painting" => "paint-bucket",
            "cleaning" => "brush",
            "landscaping" => "tree",
            "other" => "gear",
            _ => "question-circle"
        };
    }
}
