@using FixIt.BLL.DTOs
@model CreateScheduleDto

@{
    ViewData["Title"] = "Create Schedule";
}

<div class="container mt-4">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card">
                <div class="card-header bg-primary text-white">
                    <h5><i class="bi bi-calendar-plus"></i> Schedule Maintenance</h5>
                </div>
                <div class="card-body">
                    <form asp-action="CreateSchedule" method="post">
                        <input type="hidden" asp-for="IssueId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-3">
                            <label asp-for="VisitDate" class="form-label"></label>
                            <input asp-for="VisitDate" class="form-control" type="datetime-local" />
                            <span asp-validation-for="VisitDate" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="WorkerName" class="form-label"></label>
                            <input asp-for="WorkerName" class="form-control" placeholder="Enter worker name (optional)" />
                            <span asp-validation-for="WorkerName" class="text-danger"></span>
                        </div>

                        <div class="mb-3">
                            <label asp-for="EstimatedCost" class="form-label"></label>
                            <div class="input-group">
                                <span class="input-group-text">$</span>
                                <input asp-for="EstimatedCost" class="form-control" type="number" step="0.01" min="0" />
                            </div>
                            <span asp-validation-for="EstimatedCost" class="text-danger"></span>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary">
                                <i class="bi bi-check-circle"></i> Create Schedule
                            </button>
                            <a asp-action="Schedule" class="btn btn-outline-secondary">
                                <i class="bi bi-arrow-left"></i> Back to Schedule
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

@section Scripts {
    <partial name="_ValidationScriptsPartial" />
}
