@model FixIt.BLL.DTOs.DashboardStatsDto
@using FixIt.Common.Enums
@using Microsoft.AspNetCore.Identity
@using FixIt.DAL.Entities
@inject UserManager<ApplicationUser> UserManager
@{
    ViewData["Title"] = "Dashboard";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string BadgeClass(IssueStatus s) => s switch {
        IssueStatus.New        => "adm-badge adm-badge-new",
        IssueStatus.Approved   => "adm-badge adm-badge-approved",
        IssueStatus.Scheduled  => "adm-badge adm-badge-scheduled",
        IssueStatus.InProgress => "adm-badge adm-badge-inprogress",
        IssueStatus.Resolved   => "adm-badge adm-badge-resolved",
        IssueStatus.Closed     => "adm-badge adm-badge-closed",
        IssueStatus.Rejected   => "adm-badge adm-badge-rejected",
        _                      => "adm-badge"
    };

    string StatusLabel(IssueStatus s) => s switch {
        IssueStatus.InProgress => "In Progress",
        _ => s.ToString()
    };

    // Build star display (out of 5)
    double avg = Model.AverageRating;
    int fullStars  = (int)Math.Floor(avg);
    bool halfStar  = (avg - fullStars) >= 0.5;
    int emptyStars = 5 - fullStars - (halfStar ? 1 : 0);

    var currentUser = await UserManager.GetUserAsync(User);
    var displayName = currentUser?.FullName ?? User.Identity?.Name?.Split('@')[0] ?? "Admin";
}

<div class="adm-welcome-header">
    <h1 class="adm-greeting">
        Good morning, <span class="adm-username">@displayName!</span>
    </h1>
</div>

<div class="adm-dashboard-layout" style="display: flex; flex-direction: column; gap: 24px;">
    
    <!-- ── STAT CARDS ── -->
    <div class="adm-stats-grid">
        <div class="adm-stat-card">
            <div class="adm-stat-label">Total Issues</div>
            <div class="adm-stat-value">@Model.TotalIssues</div>
            <div class="adm-stat-trend">
                <span class="adm-trend-pill up">↑ 43.8%</span>
                <span class="adm-trend-text">VS last month</span>
            </div>
        </div>
        <div class="adm-stat-card">
            <div class="adm-stat-label">New Issues</div>
            <div class="adm-stat-value">@Model.NewIssues</div>
            <div class="adm-stat-trend">
                <span class="adm-trend-pill down">↓ 12.9%</span>
                <span class="adm-trend-text">VS last month</span>
            </div>
        </div>
        <div class="adm-stat-card">
            <div class="adm-stat-label">In Progress</div>
            <div class="adm-stat-value">@Model.InProgressIssues</div>
            <div class="adm-stat-trend">
                <span class="adm-trend-pill up">↑ 8.3%</span>
                <span class="adm-trend-text">VS last month</span>
            </div>
        </div>
        <div class="adm-stat-card">
            <div class="adm-stat-label">Resolved</div>
            <div class="adm-stat-value">@Model.ResolvedIssues</div>
            <div class="adm-stat-trend">
                <span class="adm-trend-pill up">↑ 22.1%</span>
                <span class="adm-trend-text">VS last month</span>
            </div>
        </div>
        <div class="adm-stat-card">
            <div class="adm-stat-label">Closed</div>
            <div class="adm-stat-value">@Model.ClosedIssues</div>
            <div class="adm-stat-trend">
                <span class="adm-trend-pill down">↓ 5.4%</span>
                <span class="adm-trend-text">VS last month</span>
            </div>
        </div>
    </div><!-- ── DASHBOARD GRID ── -->

    <!-- Performance History Table (Full Width) -->
    <div class="adm-card" style="animation-delay: 0.6s;">
        <div class="adm-card-header">
            <div class="adm-card-title">
                <span class="adm-card-icon">🕐</span> Performance History
            </div>
        </div>
        @if (Model.RecentIssues.Any())
        {
            <table class="adm-table">
                <thead>
                    <tr>
                        <th>No</th>
                        <th>Operating System (Title)</th>
                        <th>Citizen</th>
                        <th>Status</th>
                    </tr>
                </thead>
                <tbody>
                    @foreach (var (issue, index) in Model.RecentIssues.Select((v, i) => (v, i)))
                    {
                        <tr>
                            <td style="color: var(--adm-muted);">#@(index + 1)</td>
                            <td><span class="adm-issue-title" title="@issue.Title">@issue.Title</span></td>
                            <td>
                                <span class="adm-citizen-name">
                                    <span class="adm-citizen-avatar">@(string.IsNullOrWhiteSpace(issue.CitizenName) ? "?" : issue.CitizenName[0].ToString().ToUpper())</span>
                                    @issue.CitizenName
                                </span>
                            </td>
                            <td><span class="@BadgeClass(issue.Status)">@StatusLabel(issue.Status)</span></td>
                        </tr>
                    }
                </tbody>
            </table>
        }
        else
        {
            <div style="padding:40px;text-align:center;color:var(--adm-muted);font-size:14px;">No data available.</div>
        }
    </div>

    <!-- Mid Row: 3 Cards (Status Breakdown, Rating, Quick Actions) -->
    <div class="adm-row-3" style="display: grid; grid-template-columns: 1fr 1fr 1fr; gap: 24px;">        <!-- Medium Card: Status Breakdown -->
        <div class="adm-card" style="animation-delay: 0.7s;">
            <div class="adm-card-header">
                <div class="adm-card-title">
                    <span class="adm-card-icon">📌</span> Status Breakdown
                </div>
            </div>
            <div class="adm-status-list">
                <div class="adm-status-row">
                    <span class="adm-status-dot adm-dot-new"></span>
                    <span class="adm-status-name">New</span>
                    <span class="adm-status-count">@Model.NewIssues</span>
                </div>
                <div class="adm-status-row">
                    <span class="adm-status-dot adm-dot-approved"></span>
                    <span class="adm-status-name">Approved</span>
                    <span class="adm-status-count">@Model.ApprovedIssues</span>
                </div>
                <div class="adm-status-row">
                    <span class="adm-status-dot adm-dot-scheduled"></span>
                    <span class="adm-status-name">Scheduled</span>
                    <span class="adm-status-count">@Model.ScheduledIssues</span>
                </div>
                <div class="adm-status-row">
                    <span class="adm-status-dot adm-dot-inprogress"></span>
                    <span class="adm-status-name">In Progress</span>
                    <span class="adm-status-count">@Model.InProgressIssues</span>
                </div>
                <div class="adm-status-row">
                    <span class="adm-status-dot adm-dot-resolved"></span>
                    <span class="adm-status-name">Resolved</span>
                    <span class="adm-status-count">@Model.ResolvedIssues</span>
                </div>
            </div>
        </div>

        <!-- Small Card: Rating -->
        <div class="adm-card" style="animation-delay: 0.8s;">
            <div class="adm-card-header">
                <div class="adm-card-title">
                    <span class="adm-card-icon">⭐</span> Traffic Statistic (Rating)
                </div>
            </div>
            <div class="adm-rating-display" style="margin-top: 10px;">
                <div class="adm-rating-score">@(Model.AverageRating > 0 ? Model.AverageRating.ToString("F1") : "—")</div>
                <div class="adm-rating-stars">
                    @for (int i = 0; i < fullStars; i++) { <span class="adm-star adm-star-full">★</span> }
                    @if (halfStar) { <span class="adm-star adm-star-half">★</span> }
                    @for (int i = 0; i < emptyStars; i++) { <span class="adm-star adm-star-empty">★</span> }
                </div>
                <div class="adm-rating-total" style="margin-top: 20px;">
                    @(Model.TotalRatings == 0 ? "No ratings yet" : $"Based on {Model.TotalRatings} review{(Model.TotalRatings != 1 ? "s" : "")}")
                </div>
            </div>
        </div>
        <!-- Small Card: Quick Actions -->
        <div class="adm-card" style="animation-delay: 1.0s;">
            <div class="adm-card-header">
                <div class="adm-card-title">Top Actions</div>
            </div>
            <div class="adm-quick-actions">
                <a href="#" class="adm-quick-action-btn">
                    <span class="adm-qa-icon blue"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></span>
                    <span class="adm-qa-text">Review Issues (@Model.NewIssues)</span>
                </a>
                <a href="#" class="adm-quick-action-btn">
                    <span class="adm-qa-icon orange"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><circle cx="12" cy="12" r="10"></circle><polyline points="12 6 12 12 16 14"></polyline></svg></span>
                    <span class="adm-qa-text">View Schedule</span>
                </a>
                <a href="#" class="adm-quick-action-btn">
                    <span class="adm-qa-icon green"><svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2"><path d="M22 11.08V12a10 10 0 1 1-5.93-9.14"></path><polyline points="22 4 12 14.01 9 11.01"></polyline></svg></span>
                    <span class="adm-qa-text">Submit Reports</span>
                </a>
            </div>
        </div>

    </div>
</div>
