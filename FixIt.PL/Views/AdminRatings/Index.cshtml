@model IEnumerable<FixIt.Common.DTOs.AdminRatingListDto>

@{
    ViewData["Title"] = "Admin Ratings";
}

<div class="container mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <h2>Admin Ratings</h2>
    </div>

    @if (!Model.Any())
    {
        <div class="alert alert-info text-center">
            No ratings have been submitted yet.
        </div>
    }
    else
    {
        <div class="card shadow-sm">
            <div class="card-body p-0">
                <div class="table-responsive">
                    <table class="table table-hover mb-0">
                        <thead class="table-light">
                            <tr>
                                <th>ID</th>
                                <th>Issue</th>
                                <th>Citizen</th>
                                <th>Rating</th>
                                <th>Date</th>
                                <th>Actions</th>
                            </tr>
                        </thead>
                        <tbody>
                            @foreach (var rating in Model)
                            {
                                <tr>
                                    <td>@rating.RatingId</td>
                                    <td>@rating.IssueTitle</td>
                                    <td>@rating.CitizenName</td>
                                    <td>
                                        <partial name="_StarDisplay" model="rating.Stars" />
                                    </td>
                                    <td>@rating.SubmittedAt.ToString("MMM dd, yyyy")</td>
                                    <td>
                                        <a asp-action="Details" asp-route-id="@rating.RatingId" class="btn btn-sm btn-outline-primary">Details</a>
                                    </td>
                                </tr>
                            }
                        </tbody>
                    </table>
                </div>
            </div>
        </div>
    }
</div>
