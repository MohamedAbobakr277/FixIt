@model FixIt.Common.DTOs.CreateRatingDto
@{
    ViewData["Title"] = "Rate Issue Resolution";
}

<section class="section section-alt pt-5">
    <div class="section-container">
        <div class="row justify-content-center">
            <div class="col-lg-6">
                <div class="card-fixit p-5 text-center" style="margin-top: 40px;">
                    <div class="section-label mb-3">Resolution Feedback</div>
                    <h2 class="section-title mb-4">How did we do?</h2>
                    <p class="section-desc mb-5">Your feedback helps us improve community maintenance. Please rate the quality of the resolution.</p>

                    <form asp-action="Create" method="post" id="ratingForm">
                        <input type="hidden" asp-for="IssueId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <!-- ══ PREMIUM STAR INTERACTION ══ -->
                        <div class="rating-box mb-5">
                            <div class="stars-container d-flex flex-row-reverse justify-content-center gap-2">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" id="star@(i)" name="Stars" value="@i" @(Model.Stars == i ? "checked" : "") class="rating-input d-none" />
                                    <label for="star@(i)" class="rating-star-label" title="@i Stars">
                                        <svg width="48" height="48" viewBox="0 0 24 24" fill="currentColor" class="star-svg">
                                            <path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" />
                                        </svg>
                                    </label>
                                }
                            </div>
                            <div class="rating-text mt-3 fw-bold text-primary" id="ratingStatus">Select a rating</div>
                            <span asp-validation-for="Stars" class="text-danger d-block mt-2"></span>
                        </div>

                        <!-- ══ COMMENT AREA ══ -->
                        <div class="mb-5 text-start">
                            <label asp-for="Comment" class="form-label-fixit fs-5 mb-2">Share your thoughts</label>
                            <textarea asp-for="Comment" class="form-control-fixit rounded-3" rows="5" 
                                      placeholder="What went well? Is there anything we could improve?"></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                            <div class="form-text text-end mt-2 opacity-75">Max 1000 characters</div>
                        </div>

                        <div class="d-flex flex-column gap-3">
                            <button type="submit" class="btn-primary-fixit justify-content-center w-100 py-3 fs-5">
                                Submit Feedback <span class="ms-2">→</span>
                            </button>
                            <a asp-controller="Issue" asp-action="Details" asp-route-id="@Model.IssueId" 
                               class="btn-outline-fixit justify-content-center py-2">
                                Skip for now
                            </a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</section>

<style>
    .rating-box {
        background: var(--bg-surface-2);
        padding: 32px;
        border-radius: var(--radius-lg);
        border: 1.5px solid var(--border);
        transition: var(--transition);
    }
    
    [data-theme="dark"] .rating-box { background: rgba(255,255,255,0.03); }

    .rating-box:hover {
        border-color: var(--primary-glow);
        box-shadow: 0 8px 24px rgba(0, 151, 167, 0.05);
    }

    .rating-star-label {
        color: var(--border);
        cursor: pointer;
        transition: all 0.3s cubic-bezier(0.175, 0.885, 0.32, 1.275);
    }

    .rating-star-label:hover {
        transform: scale(1.2) rotate(8deg);
        color: #fbbf24;
    }

    .rating-input:checked ~ .rating-star-label,
    .rating-star-label:hover ~ .rating-star-label {
        color: #fbbf24;
        filter: drop-shadow(0 0 8px rgba(251, 191, 36, 0.4));
    }
    
    .rating-input:checked + .rating-star-label {
        transform: scale(1.3);
    }

    #ratingStatus {
        font-family: var(--font-body);
        font-size: 14px;
        letter-spacing: 0.05em;
        text-transform: uppercase;
        height: 20px;
    }

    .form-control-fixit {
        resize: none;
        transition: all 0.3s ease;
    }

    .form-control-fixit:focus {
        background: var(--bg-surface);
        transform: translateY(-2px);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
    <script>
        document.addEventListener('DOMContentLoaded', function() {
            const inputs = document.querySelectorAll('.rating-input');
            const status = document.getElementById('ratingStatus');
            const labels = {
                '1': 'Needs Improvement 😞',
                '2': 'Fair 😐',
                '3': 'Good 🙂',
                '4': 'Very Good! 😊',
                '5': 'Excellent! 🌟'
            };

            inputs.forEach(input => {
                input.addEventListener('change', function() {
                    status.textContent = labels[this.value];
                    status.style.color = 'var(--primary)';
                });
            });

            // Set initial if checked
            const checked = document.querySelector('.rating-input:checked');
            if (checked) status.textContent = labels[checked.value];
        });
    </script>
}
