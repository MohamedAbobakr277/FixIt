@model FixIt.Common.DTOs.CreateRatingDto
@{
    ViewData["Title"] = "Rate Issue Resolution";
}

<div class="container py-5">
    <div class="row justify-content-center">
        <div class="col-md-8 col-lg-6">
            <div class="card shadow-sm border-0 rounded-4">
                <div class="card-body p-5">
                    <div class="text-center mb-4">
                        <i class="bi bi-star-fill text-warning" style="font-size: 3rem;"></i>
                        <h2 class="fw-bold mt-3">Rate Resolution</h2>
                        <p class="text-muted">How satisfied are you with the resolution of your issue?</p>
                    </div>

                    <form asp-action="Create" method="post">
                        <input type="hidden" asp-for="IssueId" />
                        
                        <div asp-validation-summary="ModelOnly" class="text-danger mb-3"></div>

                        <div class="mb-4 text-center">
                            <label asp-for="Stars" class="form-label d-block fw-bold mb-3">Your Rating</label>
                            
                            <div class="star-rating d-inline-flex flex-row-reverse justify-content-center">
                                @for (int i = 5; i >= 1; i--)
                                {
                                    <input type="radio" id="star@(i)" name="Stars" value="@i" @(Model.Stars == i ? "checked" : "") class="d-none" />
                                    <label for="star@(i)" class="star-label m-1 cursor-pointer">
                                        <i class="bi bi-star-fill fs-2"></i>
                                    </label>
                                }
                            </div>
                            <span asp-validation-for="Stars" class="text-danger d-block mt-2"></span>
                        </div>

                        <div class="mb-4">
                            <label asp-for="Comment" class="form-label fw-bold">Additional Comments (Optional)</label>
                            <textarea asp-for="Comment" class="form-control rounded-3" rows="4" placeholder="Tell us about your experience..."></textarea>
                            <span asp-validation-for="Comment" class="text-danger"></span>
                            <div class="form-text text-end">Max 1000 characters</div>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg rounded-pill fw-semibold">Submit Rating</button>
                            <a asp-controller="Issue" asp-action="Details" asp-route-id="@Model.IssueId" class="btn btn-light rounded-pill">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>

<style>
    .star-label {
        color: #e4e5e9;
        transition: color 0.2s ease-in-out, transform 0.1s ease-in-out;
        cursor: pointer;
    }
    
    .star-rating input[type="radio"]:checked ~ label,
    .star-rating label:hover,
    .star-rating label:hover ~ label {
        color: #ffc107;
    }

    .star-label:active {
        transform: scale(0.9);
    }
</style>

@section Scripts {
    @{await Html.RenderPartialAsync("_ValidationScriptsPartial");}
}
