@model FixIt.BLL.DTOs.CreateIssueDto
@{
    ViewData["Title"] = "Report Issue";
}

@section Styles {
    <style>
        /* ── Premium AI Styles ── */
        .ai-panel {
            background: linear-gradient(135deg, rgba(0,188,212,.03) 0%, rgba(0,151,167,.06) 100%);
            border: 1.5px solid rgba(0,188,212,.15);
            border-radius: var(--radius-lg);
            padding: 30px;
            margin-top: 16px;
            position: relative;
            overflow: hidden;
            display: none;
        }
        .ai-panel.active { display: block; animation: fadeInPage 0.4s ease forwards; }

        .ai-panel-header { display: flex; align-items: center; gap: 16px; margin-bottom: 24px; }
        .ai-icon-large {
            width: 48px; height: 48px;
            background: linear-gradient(135deg, var(--primary), var(--primary-light));
            border-radius: 14px;
            display: flex; align-items: center; justify-content: center;
            font-size: 22px; color: white;
            box-shadow: 0 8px 16px rgba(0,188,212,.25);
        }
        .ai-panel-title { font-size: 18px; font-weight: 800; color: var(--text-heading); margin: 0 0 4px; }
        .ai-panel-subtitle { font-size: 14px; color: var(--text-muted); margin: 0; }

        .ai-upload-box {
            background: var(--bg-surface);
            border: 2px dashed var(--border-hover);
            border-radius: var(--radius-lg);
            padding: 40px;
            text-align: center;
            transition: var(--transition);
            position: relative;
        }
        .ai-upload-box:hover {
            border-color: var(--primary);
            background: var(--primary-glow);
        }
        .file-upload-input {
            position: absolute; top: 0; left: 0; width: 100%; height: 100%;
            opacity: 0; cursor: pointer; z-index: 2;
        }
        .ai-upload-icon {
            font-size: 48px; margin-bottom: 16px; color: var(--text-light); transition: var(--transition);
        }
        .ai-upload-box:hover .ai-upload-icon { color: var(--primary); transform: translateY(-4px); }
        .ai-upload-text { font-size: 16px; font-weight: 700; color: var(--text-heading); margin-bottom: 8px; }
        .ai-upload-subtext { font-size: 13px; color: var(--text-muted); }

        .image-preview {
            display: none; position: relative; margin-top: 16px;
            border-radius: var(--radius-lg); overflow: hidden;
            border: 1px solid var(--border); box-shadow: var(--card-shadow);
            background: #0f172a;
        }
        .image-preview img { 
            width: 100%; 
            height: 350px; 
            object-fit: contain; 
            display: block; 
        }
        .image-preview-remove {
            position: absolute; top: 16px; right: 16px;
            background: rgba(15, 23, 42, 0.8); color: white;
            border: none; width: 36px; height: 36px; border-radius: 50%;
            cursor: pointer; z-index: 3; font-size: 18px;
            display: flex; align-items: center; justify-content: center; transition: var(--transition);
        }
        .image-preview-remove:hover { background: #ef4444; transform: scale(1.1); }

        /* Output boxes */
        .ai-output-box {
            background: var(--bg-surface); border: 1.5px solid var(--border); border-radius: var(--radius-md);
            padding: 20px; margin-bottom: 16px;
        }
        .ai-output-label { font-size: 11px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--primary); margin-bottom: 8px; }
        .ai-output-text { font-size: 15px; color: var(--text-heading); line-height: 1.6; font-weight: 500; }

        .ai-grid { display: grid; grid-template-columns: 1fr 1fr; gap: 16px; }
        .ai-grid .ai-output-box { margin-bottom: 0; display: flex; align-items: flex-start; gap: 16px; }
        .ai-grid-icon { font-size: 28px; background: var(--bg-surface-2); padding: 12px; border-radius: 12px; }
        .ai-grid-content { flex: 1; }
        .ai-grid-value { font-size: 16px; font-weight: 800; color: var(--text-heading); margin-bottom: 4px; }
        .ai-grid-reason { font-size: 13px; color: var(--text-muted); line-height: 1.4; }

        .ai-actions { display: flex; gap: 16px; margin-top: 24px; }
        
        /* Interactive States */
        .ai-loading { display: none; text-align: center; padding: 40px 0; }
        .ai-loading.visible { display: block; animation: fadeInPage 0.3s; }
        .ai-spinner {
            width: 48px; height: 48px; border: 4px solid var(--primary-glow);
            border-top-color: var(--primary); border-radius: 50%;
            animation: spin 0.8s linear infinite; margin: 0 auto 16px;
        }

        .ai-suggestions { display: none; margin-top: 24px; }
        .ai-suggestions.visible { display: block; animation: fadeInPage 0.4s; }
        .ai-error { display: none; text-align: center; padding: 24px; color: #ef4444; background: rgba(239,68,68,0.05); border: 1.5px solid rgba(239,68,68,0.2); border-radius: var(--radius-md); font-size: 15px; font-weight: 500; }
        .ai-error.visible { display: block; }
        .ai-success { display: none; align-items: center; gap: 12px; padding: 16px 20px; background: rgba(16,185,129,0.05); color: #059669; border: 1.5px solid rgba(16,185,129,0.2); border-radius: var(--radius-md); font-size: 15px; font-weight: 600; margin-top: 20px; }
        .ai-success.visible { display: flex; animation: fadeInPage 0.3s; }

        /* Priority Dots */
        .priority-dot { width: 14px; height: 14px; border-radius: 50%; display: inline-block; }
        .priority-dot.high { background: #ef4444; box-shadow: 0 0 12px rgba(239,68,68,0.4); }
        .priority-dot.medium { background: #f59e0b; box-shadow: 0 0 12px rgba(245,158,11,0.4); }
        .priority-dot.low { background: #10b981; box-shadow: 0 0 12px rgba(16,185,129,0.4); }

        .section-header-line {
            display: flex; align-items: center; gap: 16px; margin: 40px 0 24px;
        }
        .section-header-line h3 {
            font-size: 15px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-heading); margin: 0;
        }
        .section-header-line::after {
            content: ''; flex: 1; height: 1.5px; background: var(--border);
        }

        .submit-wrap { margin-top: 40px; display: flex; justify-content: flex-end; }
        .field-error { font-size: 13px; color: #ef4444; font-weight: 500; margin-top: 6px; display: block; }

        /* ── Map Picker ── */
        .map-picker-wrap {
            border-radius: var(--radius-lg);
            border: 1.5px solid var(--border);
            overflow: hidden;
            margin-top: 12px;
            box-shadow: var(--card-shadow);
        }
        #locationSearchBox {
            width: 100%;
            padding: 12px 16px;
            font-size: 14px;
            border: none;
            border-bottom: 1.5px solid var(--border);
            background: var(--bg-surface);
            color: var(--text-heading);
            outline: none;
            font-family: var(--font-body);
        }
        #locationSearchBox::placeholder { color: var(--text-muted); }
        #issuePickerMap {
            width: 100%;
            height: 320px;
        }
        .map-coords-badge {
            display: flex; align-items: center; gap: 8px;
            padding: 10px 16px;
            background: var(--bg-surface-2);
            border-top: 1px solid var(--border);
            font-size: 13px; color: var(--text-muted);
        }
        .map-coords-badge i { color: var(--primary); }
        .map-coords-badge .coord-val { font-weight: 700; color: var(--text-heading); }
        .map-gps-hint {
            display: flex; align-items: center; gap: 8px;
            margin-top: 10px; padding: 10px 14px;
            background: rgba(0,188,212,0.06);
            border: 1px solid rgba(0,188,212,0.15);
            border-radius: var(--radius-md);
            font-size: 13px; color: var(--text-muted);
        }
        .map-gps-hint i { color: var(--primary); }
        .btn-gps {
            margin-left: auto;
            background: none;
            border: 1.5px solid var(--primary);
            color: var(--primary);
            border-radius: var(--radius-md);
            padding: 4px 12px;
            font-size: 12px; font-weight: 700;
            cursor: pointer; transition: var(--transition);
        }
        .btn-gps:hover { background: var(--primary); color: white; }
    </style>
}

<div style="min-height: 100vh; background: var(--bg-body); padding-bottom: 100px;">
    <!-- Premium Light Header -->
    <div class="cta-section" style="padding: 140px 0 110px; background: linear-gradient(180deg, #ffffff 0%, #f1f5f9 100%); position: relative; overflow: hidden; border-bottom: 1px solid #e2e8f0; margin-top: 0;">
        <!-- Premium Subtle Grid Background -->
        <div style="position: absolute; inset: 0; background-image: radial-gradient(#cbd5e1 1px, transparent 1px); background-size: 32px 32px; opacity: 0.3; pointer-events: none;"></div>
        
        <!-- Soft Top Glow -->
        <div style="position: absolute; top: 0; left: 50%; transform: translateX(-50%); width: 800px; height: 400px; background: radial-gradient(circle, rgba(0,188,212,0.08) 0%, transparent 70%); border-radius: 50%; pointer-events: none;"></div>
        
        <div class="section-container" style="text-align: center; position: relative; z-index: 2;">
            <div style="display: inline-flex; align-items: center; justify-content: center; width: 64px; height: 64px; background: #ffffff; border-radius: 20px; box-shadow: 0 10px 20px rgba(0,0,0,0.03); margin-bottom: 24px; border: 1.5px solid #e2e8f0; color: var(--primary); font-size: 28px;">
                <i class="bi bi-megaphone"></i>
            </div>
            
            <h1 style="font-family: var(--font-heading); font-size: clamp(2rem, 4vw, 3rem); font-weight: 800; color: #0f172a; margin: 0 0 16px; letter-spacing: -0.02em;">
                Report an Issue
            </h1>
            <p style="font-size: 16px; color: #475569; max-width: 600px; margin: 0 auto; line-height: 1.6; font-weight: 500;">
                Provide details about the issue or upload a photo to let our AI assist you automatically.
            </p>
        </div>
    </div>

    <!-- Main Content -->
    <div class="section-container" style="margin-top: -60px; position: relative; z-index: 10;">
        <div class="card-fixit" style="background: var(--bg-card); padding: 40px 50px; border-radius: 24px; box-shadow: 0 25px 50px -12px rgba(0, 0, 0, 0.15), 0 0 0 1px rgba(0,0,0,0.03);">
            
            <div asp-validation-summary="ModelOnly" class="alert alert-danger" style="border-radius: var(--radius-md);"></div>

            <form asp-action="Create" method="post" enctype="multipart/form-data" id="createIssueForm" novalidate>
                @Html.AntiForgeryToken()

                <!-- Step 1: Upload Photo -->
                <div class="section-header-line" style="margin-top: 0;">
                    <h3>Step 1: Visual Evidence <span style="color:var(--text-muted); font-weight:500;">(Optional)</span></h3>
                </div>
                
                <div class="ai-upload-box" id="uploadBox">
                    <input asp-for="Image" type="file" class="file-upload-input" id="Image" accept=".jpg,.jpeg,.png,.webp" />
                    <div class="ai-upload-icon"><i class="bi bi-camera"></i></div>
                    <div class="ai-upload-text" id="uploadText">Click or drag a photo here</div>
                    <div class="ai-upload-subtext">JPG, PNG, WebP up to 5MB</div>
                </div>
                <span asp-validation-for="Image" class="field-error"></span>

                <div id="imagePreview" class="image-preview">
                    <img id="previewImg" src="#" alt="Issue Image Preview" />
                    <button type="button" class="image-preview-remove" id="removeImage" title="Remove Image"><i class="bi bi-x"></i></button>
                </div>

                <!-- AI Panel -->
                <div class="ai-panel" id="aiPanel">
                    <div class="ai-panel-header">
                        <div class="ai-icon-large"><i class="bi bi-magic"></i></div>
                        <div>
                            <h3 class="ai-panel-title">AI Smart Analysis</h3>
                            <p class="ai-panel-subtitle">Automatically extract details from your photo</p>
                        </div>
                    </div>

                    <button type="button" class="btn-primary-fixit" style="width: 100%; justify-content: center; font-size: 16px; padding: 16px;" id="aiAnalyzeBtn">
                        <i class="bi bi-stars"></i> Analyze Image
                    </button>

                    <div class="ai-loading" id="aiLoading">
                        <div class="ai-spinner"></div>
                        <div style="font-weight: 700; color: var(--text-heading); font-size: 16px; margin-bottom: 4px;">AI is thinking...</div>
                        <div style="font-size: 14px; color: var(--text-muted);">This might take a few seconds.</div>
                    </div>

                    <div class="ai-error" id="aiError">
                        <div style="margin-bottom: 12px;"><i class="bi bi-exclamation-triangle" style="font-size: 24px;"></i></div>
                        <span id="aiErrorText">Something went wrong. Please fill out the form manually.</span>
                        <div style="margin-top: 16px;">
                            <button type="button" class="btn-outline-fixit" id="aiRetryBtnErr">Try Again</button>
                        </div>
                    </div>

                    <div class="ai-suggestions" id="aiSuggestions">
                        <div class="ai-output-box">
                            <div class="ai-output-label">Suggested Title</div>
                            <div class="ai-output-text" id="aiTitleValue"></div>
                        </div>
                        
                        <div class="ai-output-box">
                            <div class="ai-output-label">Suggested Description</div>
                            <div class="ai-output-text" id="aiDescValue"></div>
                        </div>

                        <div class="ai-grid">
                            <div class="ai-output-box">
                                <div class="ai-grid-icon" id="aiCategoryEmoji">📂</div>
                                <div class="ai-grid-content">
                                    <div class="ai-output-label">Category</div>
                                    <div class="ai-grid-value" id="aiCategoryValue"></div>
                                    <div class="ai-grid-reason" id="aiCategoryReason"></div>
                                </div>
                            </div>
                            <div class="ai-output-box">
                                <div class="ai-grid-icon" style="display:flex; align-items:center; justify-content:center;">
                                    <span class="priority-dot" id="aiPriorityDot"></span>
                                </div>
                                <div class="ai-grid-content">
                                    <div class="ai-output-label">Priority</div>
                                    <div class="ai-grid-value" id="aiPriorityValue"></div>
                                    <div class="ai-grid-reason" id="aiPriorityReason"></div>
                                </div>
                            </div>
                        </div>

                        <div class="ai-actions">
                            <button type="button" class="btn-primary-fixit" style="flex: 1; justify-content: center;" id="aiAcceptBtn">
                                <i class="bi bi-check2-circle"></i> Apply to Form
                            </button>
                            <button type="button" class="btn-outline-fixit" style="flex: 1; justify-content: center;" id="aiRetryBtn">
                                <i class="bi bi-arrow-clockwise"></i> Re-analyze
                            </button>
                        </div>
                    </div>

                    <div class="ai-success" id="aiAcceptedBanner">
                        <i class="bi bi-check-circle-fill" style="font-size: 20px;"></i>
                        Details applied below. Feel free to edit them before submitting.
                    </div>
                </div>

                <!-- Step 2: Details -->
                <div class="section-header-line">
                    <h3>Step 2: Issue Details</h3>
                </div>

                <div class="row g-4">
                    <div class="col-md-12">
                        <label class="form-label-fixit" for="Title">Issue Title *</label>
                        <input asp-for="Title" class="form-control-fixit" id="Title" placeholder="E.g. Broken streetlight on Main St" />
                        <span asp-validation-for="Title" class="field-error"></span>
                    </div>

                    <div class="col-md-12">
                        <label class="form-label-fixit" for="Description">Detailed Description *</label>
                        <textarea asp-for="Description" class="form-control-fixit" id="Description" rows="4" placeholder="Describe the problem, hazards, or any relevant details..."></textarea>
                        <span asp-validation-for="Description" class="field-error"></span>
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-fixit" for="Location">Exact Location *</label>
                        <input asp-for="Location" class="form-control-fixit" id="Location" placeholder="Address or specific location markers" />
                        <span asp-validation-for="Location" class="field-error"></span>
                        
                        <!-- Map Picker -->
                        <div class="map-gps-hint">
                            <i class="bi bi-geo-alt-fill"></i>
                            <span>Pin the exact location on the map for faster response</span>
                            <button type="button" class="btn-gps" id="useMyLocationBtn" title="Use my current GPS location">
                                <i class="bi bi-crosshair"></i> Use GPS
                            </button>
                        </div>
                        <div class="map-picker-wrap" id="mapPickerWrap" style="margin-top: 12px;">
                            <input id="locationSearchBox" type="text" placeholder="🔍  Search address on map..." />
                            <div id="issuePickerMap"></div>
                            <div class="map-coords-badge" id="coordsBadge" style="display:none">
                                <i class="bi bi-pin-map-fill"></i>
                                <span>Lat: <span class="coord-val" id="coordLat">—</span> &nbsp; Lng: <span class="coord-val" id="coordLng">—</span></span>
                            </div>
                        </div>
                        
                        <!-- Hidden GPS fields -->
                        <input type="hidden" asp-for="Latitude" id="Latitude" />
                        <input type="hidden" asp-for="Longitude" id="Longitude" />
                    </div>

                    <div class="col-md-6">
                        <label class="form-label-fixit" for="Category">Category *</label>
                        <select asp-for="Category" class="form-control-fixit" id="Category" asp-items="Html.GetEnumSelectList<FixIt.Common.Enums.IssueCategory>()">
                            <option value="">-- Select a Category --</option>
                        </select>
                        <span asp-validation-for="Category" class="field-error"></span>
                    </div>
                </div>

                <input type="hidden" asp-for="Priority" id="Priority" />

                <div class="submit-wrap">
                    <button type="submit" class="btn-primary-fixit" style="padding: 16px 40px; font-size: 16px;" id="createIssueSubmitBtn">
                        Submit Report <i class="bi bi-arrow-right" style="margin-left: 4px;"></i>
                    </button>
                </div>
            </form>
        </div>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        const categoryEmojis = { 'Electrical': '⚡', 'Water': '💧', 'Plumbing': '🔧', 'Carpentry': '🪚', 'GeneralMaintenance': '🔩', 'Other': '📋' };
        const categoryDisplayNames = { 'Electrical': 'Electrical', 'Water': 'Water', 'Plumbing': 'Plumbing', 'Carpentry': 'Carpentry', 'GeneralMaintenance': 'General Maintenance', 'Other': 'Other' };

        const fileInput = document.getElementById('Image');
        const uploadBox = document.getElementById('uploadBox');
        const uploadText = document.getElementById('uploadText');
        const imagePreview = document.getElementById('imagePreview');
        const previewImg = document.getElementById('previewImg');
        const removeImageBtn = document.getElementById('removeImage');

        const titleInput = document.getElementById('Title');
        const descInput = document.getElementById('Description');
        const categorySelect = document.getElementById('Category');
        const priorityInput = document.getElementById('Priority');

        const aiPanel = document.getElementById('aiPanel');
        const aiAnalyzeBtn = document.getElementById('aiAnalyzeBtn');
        const aiLoading = document.getElementById('aiLoading');
        const aiError = document.getElementById('aiError');
        const aiSuggestions = document.getElementById('aiSuggestions');
        const aiAcceptedBanner = document.getElementById('aiAcceptedBanner');

        let currentAiResult = null;
        let selectedFile = null;

        function showAiState(state) {
            aiAnalyzeBtn.style.display = state === 'ready' ? 'flex' : 'none';
            aiLoading.classList.toggle('visible', state === 'loading');
            aiError.classList.toggle('visible', state === 'error');
            aiSuggestions.classList.toggle('visible', state === 'suggestions');
            aiAcceptedBanner.classList.toggle('visible', state === 'accepted');
        }

        fileInput.addEventListener('change', function (e) {
            const file = e.target.files[0];
            if (file) {
                selectedFile = file;
                uploadBox.style.display = 'none'; // hide upload box
                
                const reader = new FileReader();
                reader.onload = function (e) {
                    previewImg.src = e.target.result;
                    imagePreview.style.display = 'block';
                };
                reader.readAsDataURL(file);

                aiPanel.classList.add('active');
                showAiState('ready');
            }
        });

        removeImageBtn.addEventListener('click', function () {
            fileInput.value = '';
            selectedFile = null;
            uploadBox.style.display = 'block';
            imagePreview.style.display = 'none';
            previewImg.src = '#';
            aiPanel.classList.remove('active');
            showAiState('');
        });

        async function analyzeWithAi() {
            if (!selectedFile) return;

            showAiState('loading');

            try {
                const formData = new FormData();
                formData.append('image', selectedFile);

                const response = await fetch('/Issue/ClassifyFromImage', {
                    method: 'POST',
                    body: formData
                });

                if (!response.ok) {
                    const err = await response.json().catch(() => ({}));
                    document.getElementById('aiErrorText').textContent =
                        err.error || 'Could not analyze the image. Please fill in the details manually.';
                    showAiState('error');
                    return;
                }

                currentAiResult = await response.json();
                
                // Populate preview
                document.getElementById('aiTitleValue').textContent = currentAiResult.title;
                document.getElementById('aiDescValue').textContent = currentAiResult.description;
                document.getElementById('aiCategoryEmoji').textContent = categoryEmojis[currentAiResult.category] || '📂';
                document.getElementById('aiCategoryValue').textContent = categoryDisplayNames[currentAiResult.category] || currentAiResult.category;
                document.getElementById('aiCategoryReason').textContent = currentAiResult.categoryReason;
                
                const priDot = document.getElementById('aiPriorityDot');
                priDot.className = 'priority-dot ' + currentAiResult.priority.toLowerCase();
                document.getElementById('aiPriorityValue').textContent = currentAiResult.priority;
                document.getElementById('aiPriorityReason').textContent = currentAiResult.priorityReason;

                showAiState('suggestions');

            } catch (err) {
                console.error('AI error:', err);
                showAiState('error');
            }
        }

        document.getElementById('aiAnalyzeBtn').addEventListener('click', analyzeWithAi);
        
        document.getElementById('aiAcceptBtn').addEventListener('click', () => {
            if (!currentAiResult) return;
            titleInput.value = currentAiResult.title;
            descInput.value = currentAiResult.description;
            categorySelect.value = currentAiResult.categoryValue;
            priorityInput.value = currentAiResult.priorityValue;
            showAiState('accepted');
            
            // Auto scroll to form
            titleInput.scrollIntoView({ behavior: 'smooth', block: 'center' });
        });

        document.getElementById('aiRetryBtn').addEventListener('click', analyzeWithAi);
        document.getElementById('aiRetryBtnErr').addEventListener('click', analyzeWithAi);

        document.getElementById('createIssueForm').addEventListener('submit', function () {
            const btn = document.getElementById('createIssueSubmitBtn');
            btn.disabled = true;
            btn.innerHTML = 'Submitting... <i class="bi bi-hourglass-split"></i>';
        });
    </script>
}

    <!-- ── Leaflet.js + OpenStreetMap (free, no API key) ── -->
    <link rel="stylesheet" href="https://unpkg.com/leaflet@1.9.4/dist/leaflet.css" />
    <script src="https://unpkg.com/leaflet@1.9.4/dist/leaflet.js"></script>
    <script>
    (function() {
        const latInput    = document.getElementById('Latitude');
        const lngInput    = document.getElementById('Longitude');
        const locInput    = document.getElementById('Location');
        const coordsBadge = document.getElementById('coordsBadge');
        const coordLat    = document.getElementById('coordLat');
        const coordLng    = document.getElementById('coordLng');
        const searchBox   = document.getElementById('locationSearchBox');

        // Default centre: Cairo
        const DEFAULT_LAT = 30.0444, DEFAULT_LNG = 31.2357;

        const map = L.map('issuePickerMap', { zoomControl: true }).setView([DEFAULT_LAT, DEFAULT_LNG], 12);

        L.tileLayer('https://{s}.tile.openstreetmap.org/{z}/{x}/{y}.png', {
            attribution: '© <a href="https://www.openstreetmap.org/copyright">OpenStreetMap</a>',
            maxZoom: 19
        }).addTo(map);

        // Custom teal pin icon
        const pinIcon = L.divIcon({
            className: '',
            html: '<div style="width:20px;height:20px;background:var(--primary,#00bcd4);border:3px solid white;border-radius:50% 50% 50% 0;transform:rotate(-45deg);box-shadow:0 2px 8px rgba(0,0,0,0.3)"></div>',
            iconSize: [20, 20],
            iconAnchor: [10, 20]
        });

        let marker = null;

        function updatePin(lat, lng) {
            if (marker) { marker.setLatLng([lat, lng]); }
            else {
                marker = L.marker([lat, lng], { icon: pinIcon, draggable: true }).addTo(map);
                marker.on('dragend', function(e) {
                    const p = e.target.getLatLng();
                    setCoords(p.lat, p.lng);
                    reverseGeocode(p.lat, p.lng);
                });
            }
            setCoords(lat, lng);
            coordsBadge.style.display = 'flex';
        }

        function setCoords(lat, lng) {
            latInput.value    = lat.toFixed(7);
            lngInput.value    = lng.toFixed(7);
            coordLat.textContent = lat.toFixed(5);
            coordLng.textContent = lng.toFixed(5);
        }

        // Nominatim reverse geocoding (free OSM service)
        async function reverseGeocode(lat, lng) {
            try {
                const r = await fetch(
                    `https://nominatim.openstreetmap.org/reverse?format=jsonv2&lat=${lat}&lon=${lng}`,
                    { headers: { 'Accept-Language': 'en' } }
                );
                const data = await r.json();
                if (data && data.display_name && !locInput.value) {
                    locInput.value = data.display_name;
                }
            } catch {}
        }

        // Click on map → place pin
        map.on('click', function(e) {
            updatePin(e.latlng.lat, e.latlng.lng);
            reverseGeocode(e.latlng.lat, e.latlng.lng);
        });

        // Search box → Nominatim forward geocoding
        let searchTimer;
        searchBox.addEventListener('input', function() {
            clearTimeout(searchTimer);
            const q = this.value.trim();
            if (q.length < 3) return;
            searchTimer = setTimeout(async () => {
                try {
                    const r = await fetch(
                        `https://nominatim.openstreetmap.org/search?format=json&q=${encodeURIComponent(q)}&limit=5`,
                        { headers: { 'Accept-Language': 'en' } }
                    );
                    const results = await r.json();
                    showSuggestions(results);
                } catch {}
            }, 400);
        });

        // Simple dropdown suggestions
        let suggestBox = null;
        function showSuggestions(results) {
            removeSuggestions();
            if (!results.length) return;
            suggestBox = document.createElement('div');
            suggestBox.style.cssText = 'position:absolute;z-index:9999;background:white;border:1.5px solid #e2e8f0;border-radius:10px;box-shadow:0 8px 24px rgba(0,0,0,0.12);max-height:220px;overflow-y:auto;width:100%;left:0;top:100%;margin-top:4px;';
            results.forEach(r => {
                const item = document.createElement('div');
                item.style.cssText = 'padding:10px 14px;cursor:pointer;font-size:13px;border-bottom:1px solid #f1f5f9;color:#374151;';
                item.textContent = r.display_name;
                item.onmouseenter = () => item.style.background = '#f0f9ff';
                item.onmouseleave = () => item.style.background = '';
                item.onclick = () => {
                    const lat = parseFloat(r.lat), lng = parseFloat(r.lon);
                    map.setView([lat, lng], 16);
                    updatePin(lat, lng);
                    locInput.value = r.display_name;
                    searchBox.value = r.display_name;
                    removeSuggestions();
                };
                suggestBox.appendChild(item);
            });
            // Position relative to the search box wrapper
            const wrap = searchBox.parentElement;
            wrap.style.position = 'relative';
            wrap.appendChild(suggestBox);
        }
        function removeSuggestions() {
            if (suggestBox) { suggestBox.remove(); suggestBox = null; }
        }
        document.addEventListener('click', e => { if (!searchBox.contains(e.target)) removeSuggestions(); });

        // GPS button
        document.getElementById('useMyLocationBtn').addEventListener('click', function() {
            if (!navigator.geolocation) { alert('Geolocation not supported by your browser.'); return; }
            this.innerHTML = '<i class="bi bi-hourglass-split"></i> Locating...';
            const btn = this;
            navigator.geolocation.getCurrentPosition(
                function(pos) {
                    const lat = pos.coords.latitude, lng = pos.coords.longitude;
                    map.setView([lat, lng], 17);
                    updatePin(lat, lng);
                    reverseGeocode(lat, lng);
                    btn.innerHTML = '<i class="bi bi-check-circle-fill"></i> Located!';
                    setTimeout(() => { btn.innerHTML = '<i class="bi bi-crosshair"></i> Use GPS'; }, 2500);
                },
                function() {
                    alert('Could not get your location. Please pin manually on the map.');
                    btn.innerHTML = '<i class="bi bi-crosshair"></i> Use GPS';
                },
                { enableHighAccuracy: true, timeout: 8000 }
            );
        });
    })();
    </script>
}



