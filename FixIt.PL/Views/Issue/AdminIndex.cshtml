@model FixIt.BLL.DTOs.AdminIssueListPageDto
@using FixIt.Common.Enums
@{
    ViewData["Title"] = "Issues Management";
    Layout = "~/Views/Shared/_AdminLayout.cshtml";

    string Search = Model.SearchTerm ?? "";
    IssueStatus? Active = Model.StatusFilter;

    string ChipClass(IssueStatus? s) =>
        (Active == s) ? "iss-chip iss-chip-active" : "iss-chip";

    string CategoryIcon(IssueCategory c) => c switch
    {
        IssueCategory.Electrical          => "⚡",
        IssueCategory.Water               => "💧",
        IssueCategory.Plumbing            => "🔧",
        IssueCategory.Carpentry           => "🪚",
        IssueCategory.GeneralMaintenance  => "🛠",
        _                                 => "📌"
    };

    string CategoryLabel(IssueCategory c) => c switch
    {
        IssueCategory.GeneralMaintenance => "General Maintenance",
        _ => c.ToString()
    };

    string StatusLabel(IssueStatus s) => s switch
    {
        IssueStatus.InProgress => "In Progress",
        _ => s.ToString()
    };

    string StatusBadgeClass(IssueStatus s) => s switch
    {
        IssueStatus.New        => "adm-badge adm-badge-new",
        IssueStatus.Approved   => "adm-badge adm-badge-approved",
        IssueStatus.Scheduled  => "adm-badge adm-badge-scheduled",
        IssueStatus.InProgress => "adm-badge adm-badge-inprogress",
        IssueStatus.Resolved   => "adm-badge adm-badge-resolved",
        IssueStatus.Closed     => "adm-badge adm-badge-closed",
        IssueStatus.Rejected   => "adm-badge adm-badge-rejected",
        _                      => "adm-badge"
    };
}

@section Styles {
<style>
    .iss-page-head { margin-bottom: 20px; }
    .iss-page-head h1 {
        font-size: 26px;
        font-weight: 700;
        color: var(--adm-text);
        margin: 0 0 6px;
        letter-spacing: -0.01em;
    }
    .iss-page-head p {
        color: var(--adm-muted);
        font-size: 14px;
        margin: 0;
    }

    .iss-toolbar {
        background: var(--adm-surface);
        border: 1px solid var(--adm-border);
        border-radius: var(--adm-radius);
        padding: 16px 20px;
        display: flex;
        align-items: center;
        gap: 16px;
        flex-wrap: wrap;
        box-shadow: var(--adm-card-shadow);
        margin-bottom: 20px;
    }
    .iss-search {
        flex: 1 1 280px;
        position: relative;
    }
    .iss-search input {
        width: 100%;
        height: 40px;
        padding: 0 14px 0 38px;
        border-radius: 10px;
        border: 1px solid var(--adm-border);
        background: var(--adm-bg);
        color: var(--adm-text);
        font-size: 14px;
        font-family: var(--adm-font);
        outline: none;
        transition: border-color .2s, box-shadow .2s;
    }
    .iss-search input:focus {
        border-color: var(--adm-primary);
        box-shadow: 0 0 0 3px var(--adm-primary-glow);
    }
    .iss-search svg {
        position: absolute;
        left: 12px;
        top: 50%;
        transform: translateY(-50%);
        color: var(--adm-muted);
    }

    .iss-chips {
        display: flex;
        gap: 6px;
        flex-wrap: wrap;
    }
    .iss-chip {
        padding: 7px 14px;
        border: 1px solid var(--adm-border);
        background: transparent;
        color: var(--adm-text);
        border-radius: 8px;
        font-size: 13px;
        font-weight: 500;
        font-family: var(--adm-font);
        cursor: pointer;
        text-decoration: none;
        transition: background .15s, border-color .15s, color .15s;
        display: inline-flex;
        align-items: center;
    }
    .iss-chip:hover {
        border-color: var(--adm-primary);
        color: var(--adm-primary);
    }
    .iss-chip-active,
    .iss-chip-active:hover {
        background: var(--adm-primary);
        border-color: var(--adm-primary);
        color: #fff;
    }

    .iss-card {
        background: var(--adm-surface);
        border: 1px solid var(--adm-border);
        border-radius: var(--adm-radius);
        box-shadow: var(--adm-card-shadow);
        overflow: hidden;
    }
    .iss-card-head {
        padding: 18px 24px;
        border-bottom: 1px solid var(--adm-border);
    }
    .iss-card-head h2 {
        margin: 0;
        font-size: 16px;
        font-weight: 600;
        color: var(--adm-text);
    }
    .iss-card-head small {
        display: block;
        color: var(--adm-muted);
        font-size: 12.5px;
        margin-top: 2px;
    }

    .iss-table { width: 100%; border-collapse: collapse; }
    .iss-table thead th {
        text-align: left;
        font-size: 12px;
        font-weight: 600;
        color: var(--adm-muted);
        text-transform: none;
        padding: 12px 24px;
        background: transparent;
        border-bottom: 1px solid var(--adm-border);
        letter-spacing: 0.01em;
    }
    .iss-table tbody td {
        padding: 18px 24px;
        font-size: 13.5px;
        color: var(--adm-text);
        border-bottom: 1px solid var(--adm-border);
        vertical-align: middle;
    }
    .iss-table tbody tr:last-child td { border-bottom: none; }
    .iss-table tbody tr:hover { background: var(--adm-surface-2); }

    .iss-id { color: var(--adm-muted); font-weight: 500; font-size: 13px; }
    .iss-title-main { font-weight: 600; color: var(--adm-text); margin-bottom: 2px; }
    .iss-title-sub { font-size: 12.5px; color: var(--adm-muted); }

    .iss-category {
        display: inline-flex;
        align-items: center;
        gap: 8px;
        color: var(--adm-text);
        font-weight: 500;
        font-size: 13px;
    }
    .iss-cat-icon { font-size: 15px; line-height: 1; }

    .iss-date {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--adm-muted);
        font-size: 13px;
    }

    .iss-view-link {
        display: inline-flex;
        align-items: center;
        gap: 6px;
        color: var(--adm-primary);
        text-decoration: none;
        font-size: 13px;
        font-weight: 500;
        transition: color .15s;
    }
    .iss-view-link:hover { color: var(--adm-primary-dark); }

    .iss-empty {
        padding: 60px 20px;
        text-align: center;
        color: var(--adm-muted);
        font-size: 14px;
    }
</style>
}

<div class="iss-page-head">
    <h1>Issues Management</h1>
    <p>View and manage all reported community issues</p>
</div>

<form method="get" asp-action="AdminIndex" class="iss-toolbar" id="issToolbar">
    <div class="iss-search">
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
            <circle cx="11" cy="11" r="8"></circle>
            <line x1="21" y1="21" x2="16.65" y2="16.65"></line>
        </svg>
        <input type="search" name="search" value="@Search" placeholder="Search issues by title, ID, location..." />
    </div>
    <div class="iss-chips">
        <a class="@ChipClass(null)" asp-action="AdminIndex">All</a>
        @foreach (var st in new[] { IssueStatus.New, IssueStatus.Approved, IssueStatus.Scheduled, IssueStatus.InProgress, IssueStatus.Resolved, IssueStatus.Rejected })
        {
            <a class="@ChipClass(st)" asp-action="AdminIndex" asp-route-status="@st" asp-route-search="@Search">@StatusLabel(st)</a>
        }
    </div>
    @if (Active.HasValue)
    {
        <input type="hidden" name="status" value="@Active" />
    }
</form>

<div class="iss-card">
    <div class="iss-card-head">
        <h2>@(Active.HasValue ? StatusLabel(Active.Value) + " Issues" : "All Issues")</h2>
        <small>@Model.TotalCount issue@(Model.TotalCount == 1 ? "" : "s") found</small>
    </div>

    @if (!Model.Items.Any())
    {
        <div class="iss-empty">No issues match the current filters.</div>
    }
    else
    {
        <div style="overflow-x:auto;">
            <table class="iss-table">
                <thead>
                    <tr>
                        <th>Issue ID</th>
                        <th>Title</th>
                        <th>Category</th>
                        <th>Status</th>
                        <th>Date</th>
                        <th>Actions</th>
                    </tr>
                </thead>
                <tbody>
                @foreach (var item in Model.Items)
                {
                    <tr onclick="location.href='@Url.Action("AdminDetails", "Issue", new { id = item.IssueId })'" style="cursor: pointer;">
                        <td><span class="iss-id">ISS-@item.IssueId.ToString("D3")</span></td>
                        <td>
                            <div class="iss-title-main">@item.Title</div>
                            <div class="iss-title-sub">@item.CitizenName</div>
                        </td>
                        <td>
                            <span class="iss-category">
                                <span class="iss-cat-icon">@CategoryIcon(item.Category)</span>
                                @CategoryLabel(item.Category)
                            </span>
                        </td>
                        <td><span class="@StatusBadgeClass(item.Status)">@StatusLabel(item.Status)</span></td>
                        <td>
                            <span class="iss-date">
                                <svg width="14" height="14" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <rect x="3" y="4" width="18" height="18" rx="2" ry="2"></rect>
                                    <line x1="16" y1="2" x2="16" y2="6"></line>
                                    <line x1="8" y1="2" x2="8" y2="6"></line>
                                    <line x1="3" y1="10" x2="21" y2="10"></line>
                                </svg>
                                @item.SubmittedAt.ToString("M/d/yyyy")
                            </span>
                        </td>
                        <td>
                            <a class="iss-view-link" asp-action="AdminDetails" asp-route-id="@item.IssueId">
                                <svg width="15" height="15" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round">
                                    <path d="M1 12s4-8 11-8 11 8 11 8-4 8-11 8-11-8-11-8z"></path>
                                    <circle cx="12" cy="12" r="3"></circle>
                                </svg>
                                View
                            </a>
                        </td>
                    </tr>
                }
                </tbody>
            </table>
        </div>
    }
</div>

@section Scripts {
<script>
document.addEventListener('DOMContentLoaded', function () {
    var input = document.querySelector('#issToolbar input[name="search"]');
    var form = document.getElementById('issToolbar');
    var rows = document.querySelectorAll('.iss-table tbody tr');
    
    if (!input || rows.length === 0) return;

    // Remove the name attribute so pressing Enter doesn't submit 'search' param if we don't want to
    // But keeping it is fine if they still want server search on enter. We'll just prevent default on enter.
    input.addEventListener('keydown', function (e) {
        if (e.key === 'Enter') { 
            e.preventDefault(); 
        }
    });

    input.addEventListener('input', function () {
        var term = input.value.trim().toLowerCase();

        rows.forEach(function (row) {
            // Get all text content from the row
            var rowText = row.textContent.toLowerCase();
            
            if (rowText.includes(term)) {
                row.style.display = '';
            } else {
                row.style.display = 'none';
            }
        });
    });
});
</script>
}
