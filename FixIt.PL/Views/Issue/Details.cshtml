@model FixIt.BLL.DTOs.IssueDetailsDto
@using FixIt.Common.Enums
@{
    ViewData["Title"] = $"Issue Details - {Model.Title}";
}

@section Styles {
    <style>
        /* Animations */
        @@keyframes slideUpFade {
            from { opacity: 0; transform: translateY(20px); }
            to { opacity: 1; transform: translateY(0); }
        }

        .issue-details-container {
            display: flex;
            flex-direction: column;
            gap: 2rem;
            padding: 3rem 5%;
            margin-top: 60px;
            max-width: 1200px;
            margin-left: auto;
            margin-right: auto;
        }

        .issue-details-header {
            background: var(--bg-surface);
            border: 1px solid rgba(0, 151, 167, 0.15);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05), inset 0 0 0 1px rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            animation: slideUpFade 0.5s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .issue-title-section {
            display: flex;
            justify-content: space-between;
            align-items: flex-start;
            margin-bottom: 1.5rem;
            gap: 1rem;
        }

        .issue-title h1 {
            font-size: 2rem;
            font-weight: 700;
            color: var(--text-heading);
            margin: 0;
            line-height: 1.2;
        }

        .issue-badges {
            display: flex;
            gap: 12px;
            flex-wrap: wrap;
        }

        .badge {
            padding: 6px 16px;
            border-radius: 20px;
            font-size: 12.5px;
            font-weight: 600;
            text-transform: uppercase;
            letter-spacing: 0.5px;
            position: relative;
            border: 1px solid;
        }

        .badge::before {
            content: '';
            position: absolute;
            left: 8px;
            top: 50%;
            transform: translateY(-50%);
            width: 6px;
            height: 6px;
            border-radius: 50%;
        }

        .badge-status-new { background: rgba(34, 197, 94, 0.1); color: #22c55e; border-color: rgba(34, 197, 94, 0.2); }
        .badge-status-new::before { background: #22c55e; }

        .badge-status-in-progress { background: rgba(59, 130, 246, 0.1); color: #3b82f6; border-color: rgba(59, 130, 246, 0.2); }
        .badge-status-in-progress::before { background: #3b82f6; }

        .badge-status-resolved { background: rgba(168, 85, 247, 0.1); color: #a855f7; border-color: rgba(168, 85, 247, 0.2); }
        .badge-status-resolved::before { background: #a855f7; }

        .badge-status-closed { background: rgba(71, 85, 105, 0.1); color: #475569; border-color: rgba(71, 85, 105, 0.2); }
        .badge-status-closed::before { background: #475569; }

        .badge-category {
            background: rgba(0, 151, 167, 0.1);
            color: var(--primary);
            border-color: rgba(0, 151, 167, 0.2);
        }
        .badge-category::before { background: var(--primary); }

        .badge-priority {
            background: rgba(239, 68, 68, 0.1);
            color: #ef4444;
            border-color: rgba(239, 68, 68, 0.2);
        }
        .badge-priority::before { background: #ef4444; }

        .issue-meta {
            display: flex;
            gap: 2rem;
            margin-bottom: 1.5rem;
            flex-wrap: wrap;
        }

        .meta-item {
            display: flex;
            align-items: center;
            gap: 8px;
            color: var(--text-muted);
            font-size: 14px;
        }

        .meta-item svg {
            width: 16px;
            height: 16px;
        }

        .issue-description {
            margin-bottom: 2rem;
        }

        .issue-description h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 0.75rem;
        }

        .description-text {
            color: var(--text-body);
            line-height: 1.6;
            font-size: 15px;
        }

        .issue-image {
            margin-bottom: 2rem;
        }

        .issue-image h3 {
            font-size: 1.1rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 0.75rem;
        }

        .issue-image img {
            width: 100%;
            max-width: 600px;
            height: auto;
            border-radius: var(--radius-md);
            border: 1px solid var(--border);
        }

        .issue-actions {
            display: flex;
            gap: 1rem;
            margin-top: 2rem;
            flex-wrap: wrap;
        }

        .btn-back {
            padding: 10px 24px;
            background: transparent;
            color: var(--text-body);
            border: 1px solid var(--border);
            border-radius: 20px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-back:hover {
            background: var(--bg-surface);
            transform: translateX(-2px);
        }

        .btn-rate {
            padding: 10px 24px;
            background: linear-gradient(135deg, var(--primary), #00a8b5);
            color: white;
            border: none;
            border-radius: 20px;
            font-weight: 600;
            text-decoration: none;
            display: flex;
            align-items: center;
            gap: 8px;
            transition: all 0.2s;
        }

        .btn-rate:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 25px rgba(0, 151, 167, 0.3);
        }

        .admin-notes {
            background: rgba(255, 193, 7, 0.1);
            border: 1px solid rgba(255, 193, 7, 0.2);
            border-radius: var(--radius-md);
            padding: 1rem;
            margin-top: 1.5rem;
        }

        .admin-notes h4 {
            color: #ffc107;
            font-size: 0.9rem;
            font-weight: 600;
            margin-bottom: 0.5rem;
        }

        .admin-notes p {
            color: var(--text-body);
            margin: 0;
            line-height: 1.5;
        }

        .related-info {
            background: var(--bg-surface);
            border: 1px solid rgba(0, 151, 167, 0.15);
            border-radius: var(--radius-lg);
            padding: 2rem;
            box-shadow: 0 10px 30px rgba(0,0,0,0.05), inset 0 0 0 1px rgba(255,255,255,0.05);
            backdrop-filter: blur(12px);
            animation: slideUpFade 0.6s cubic-bezier(0.16, 1, 0.3, 1) forwards;
        }

        .related-info h3 {
            font-size: 1.2rem;
            font-weight: 600;
            color: var(--text-heading);
            margin-bottom: 1.5rem;
        }

        .info-grid {
            display: grid;
            grid-template-columns: repeat(auto-fit, minmax(250px, 1fr));
            gap: 1.5rem;
        }

        .info-card {
            padding: 1rem;
            background: rgba(255,255,255,0.02);
            border: 1px solid var(--border);
            border-radius: var(--radius-md);
        }

        .info-card h4 {
            font-size: 0.9rem;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 0.5rem;
            text-transform: uppercase;
            letter-spacing: 0.5px;
        }

        .info-card p {
            color: var(--text-body);
            margin: 0;
        }

        .no-info {
            color: var(--text-muted);
            font-style: italic;
        }

        @@media (max-width: 768px) {
            .issue-details-container {
                padding: 2rem 3%;
            }

            .issue-title-section {
                flex-direction: column;
                align-items: flex-start;
            }

            .issue-title h1 {
                font-size: 1.5rem;
            }

            .issue-meta {
                flex-direction: column;
                gap: 1rem;
            }

            .issue-actions {
                flex-direction: column;
            }

            .btn-back, .btn-rate {
                justify-content: center;
            }
        }
    </style>
}

<div class="issue-details-container">
    <!-- Issue Header -->
    <div class="issue-details-header">
        <div class="issue-title-section">
            <div class="issue-title">
                <h1>@Model.Title</h1>
            </div>
            <div class="issue-badges">
                <span class="badge badge-status-@Model.Status.ToString().ToLower().Replace('_', '-')">@Model.Status</span>
                <span class="badge badge-category">@Model.Category</span>
                <span class="badge badge-priority">@Model.Priority</span>
            </div>
        </div>

        <div class="issue-meta">
            <div class="meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M21 16V8a2 2 0 0 0-1-1.73l-7-4a2 2 0 0 0-2 0l-7 4A2 2 0 0 0 3 8v8a2 2 0 0 0 1 1.73l7 4a2 2 0 0 0 2 0l7-4A2 2 0 0 0 21 16z"></path>
                </svg>
                @Model.Location
            </div>
            <div class="meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <circle cx="12" cy="12" r="10"></circle>
                    <polyline points="12 6 12 12 16 14"></polyline>
                </svg>
                Submitted: @Model.SubmittedAt.ToString("MMM dd, yyyy")
            </div>
            <div class="meta-item">
                <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2">
                    <path d="M11 4H4a2 2 0 0 0-2 2v14a2 2 0 0 0 2 2h14a2 2 0 0 0 2-2v-7"></path>
                    <path d="M18.5 2.5a2.121 2.121 0 0 1 3 3L12 15l-4 1 1-4 9.5-9.5z"></path>
                </svg>
                Updated: @Model.UpdatedAt.ToString("MMM dd, yyyy")
            </div>
        </div>

        <div class="issue-description">
            <h3>Description</h3>
            <div class="description-text">@Model.Description</div>
        </div>

        @if (!string.IsNullOrEmpty(Model.ImageUrl))
        {
            <div class="issue-image">
                <h3>Attached Image</h3>
                <img src="@Model.ImageUrl" alt="Issue image" />
            </div>
        }

        @if (!string.IsNullOrEmpty(Model.AdminNotes))
        {
            <div class="admin-notes">
                <h4>📝 Admin Notes</h4>
                <p>@Model.AdminNotes</p>
            </div>
        }

        <div class="issue-actions">
            <a asp-action="Index" class="btn-back">
                <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round">
                    <line x1="19" y1="12" x2="5" y2="12"></line>
                    <polyline points="12 19 5 12 12 5"></polyline>
                </svg>
                Back to My Issues
            </a>

            @if (Model.Status == "Resolved" && Model.Rating == null)
            {
                <a asp-controller="Rating" asp-action="Create" asp-route-issueId="@Model.IssueId" class="btn-rate">
                    <svg width="16" height="16" viewBox="0 0 24 24" fill="currentColor" stroke="currentColor" stroke-width="2">
                        <polygon points="12 2 15.09 8.26 22 9.27 17 14.14 18.18 21.02 12 17.77 5.82 21.02 7 14.14 2 9.27 8.91 8.26 12 2"></polygon>
                    </svg>
                    Rate This Service
                </a>
            }
        </div>
    </div>

    <!-- Related Information -->
    <div class="related-info">
        <h3>Related Information</h3>
        <div class="info-grid">
            <div class="info-card">
                <h4>Reported By</h4>
                <p>@Model.CitizenName</p>
            </div>

            @if (Model.Schedule != null)
            {
                <div class="info-card">
                    <h4>Scheduled Visit</h4>
                    <p>@Model.Schedule.VisitDate.ToString("MMM dd, yyyy")</p>
                    <p>Est. Cost: $@Model.Schedule.EstimatedCost.ToString("F2")</p>
                </div>
            }
            else
            {
                <div class="info-card">
                    <h4>Scheduled Visit</h4>
                    <p class="no-info">Not scheduled yet</p>
                </div>
            }

            @if (Model.Report != null)
            {
                <div class="info-card">
                    <h4>Maintenance Report</h4>
                    <p>@Model.Report.Summary</p>
                    <p>Completed: @Model.Report.SubmittedAt.ToString("MMM dd, yyyy")</p>
                </div>
            }
            else
            {
                <div class="info-card">
                    <h4>Maintenance Report</h4>
                    <p class="no-info">No report available</p>
                </div>
            }

            @if (Model.Rating != null)
            {
                <div class="info-card">
                    <h4>Your Rating</h4>
                    <p>⭐ @Model.Rating.Stars out of 5</p>
                    @if (!string.IsNullOrEmpty(Model.Rating.Comment))
                    {
                        <p>"@Model.Rating.Comment"</p>
                    }
                </div>
            }
            else
            {
                <div class="info-card">
                    <h4>Your Rating</h4>
                    <p class="no-info">Not rated yet</p>
                </div>
            }
        </div>
    </div>
</div>
