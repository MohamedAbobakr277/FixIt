@model FixIt.Common.DTOs.IssueDetailsDto
@using FixIt.Common.Enums
@using System.Security.Claims
@{
    ViewData["Title"] = $"Issue #{Model.IssueId} - {Model.Title}";
    
    var statuses = new List<(string Key, string Display, string Desc)>
    {
        ("New", "New", "Issue submitted successfully"),
        ("Approved", "Approved", "Issue approved by administration"),
        ("Scheduled", "Scheduled", Model.Schedule != null ? $"Maintenance scheduled with {Model.Schedule.WorkerName}" : "Scheduling maintenance visit"),
        ("InProgress", "In Progress", "Crew is on-site performing repairs"),
        ("Resolved", "Resolved", "Resolution report submitted"),
        ("Closed", "Closed", "Issue closed by citizen feedback")
    };

    int GetWeight(string status) => status switch
    {
        "New" => 1,
        "Approved" => 2,
        "Scheduled" => 3,
        "InProgress" => 4,
        "In Progress" => 4,
        "Resolved" => 5,
        "Closed" => 6,
        "Rejected" => -1,
        _ => 0
    };

    int currentWeight = GetWeight(Model.Status);
    bool isRejected = Model.Status == "Rejected";
}

@section Styles {
    <style>
        .issue-hero {
            background: linear-gradient(145deg, var(--bg-surface) 0%, rgba(0, 188, 212, 0.03) 100%);
            border: 1px solid var(--border);
            border-radius: var(--radius-lg);
            padding: 48px;
            margin-bottom: 40px;
            box-shadow: var(--card-shadow);
            position: relative;
            overflow: hidden;
        }
        
        .issue-hero::after {
            content: ''; position: absolute; top: -50%; right: -10%; width: 400px; height: 400px;
            background: radial-gradient(circle, var(--primary-glow) 0%, transparent 70%);
            opacity: 0.5; pointer-events: none;
        }

        .issue-details-title { font-size: 36px; font-weight: 800; color: var(--text-heading); margin: 0 0 24px 0; letter-spacing: -0.5px; line-height: 1.3; }
        
        .issue-meta-tags { display: flex; flex-wrap: wrap; gap: 12px; margin-bottom: 24px; position: relative; z-index: 1; }
        .meta-tag { padding: 6px 16px; border-radius: 20px; font-size: 13px; font-weight: 700; text-transform: uppercase; letter-spacing: 1px; display: inline-flex; align-items: center; gap: 6px; }
        .meta-tag.status-new { background: rgba(0, 188, 212, 0.1); color: var(--primary); }
        .meta-tag.status-approved { background: rgba(59, 130, 246, 0.1); color: #3b82f6; }
        .meta-tag.status-scheduled { background: rgba(139, 92, 246, 0.1); color: #8b5cf6; }
        .meta-tag.status-inprogress { background: rgba(245, 158, 11, 0.1); color: #f59e0b; }
        .meta-tag.status-resolved { background: rgba(16, 185, 129, 0.1); color: #10b981; }
        .meta-tag.status-closed { background: rgba(100, 116, 139, 0.1); color: #64748b; }
        .meta-tag.status-rejected { background: rgba(239, 68, 68, 0.1); color: #ef4444; }
        .meta-tag.id { background: var(--bg-surface-2); color: var(--text-muted); border: 1px solid var(--border); }

        .issue-hero-info { display: flex; flex-wrap: wrap; gap: 32px; position: relative; z-index: 1; }
        .hero-info-item { display: flex; align-items: center; gap: 10px; font-size: 15px; color: var(--text-muted); font-weight: 600; }
        .hero-info-item i { font-size: 18px; color: var(--primary); background: var(--primary-glow); padding: 8px; border-radius: 50%; }

        .section-header-line { display: flex; align-items: center; gap: 12px; margin-bottom: 24px; }
        .section-header-line h3 { font-size: 16px; font-weight: 800; text-transform: uppercase; letter-spacing: 0.1em; color: var(--text-heading); margin: 0; }
        .section-header-line i { color: var(--primary); font-size: 20px; }

        .desc-text { font-size: 16px; line-height: 1.8; color: var(--text-body); margin-bottom: 32px; }
        
        .issue-image { width: 100%; border-radius: var(--radius-lg); box-shadow: var(--card-shadow); border: 1px solid var(--border); max-height: 450px; object-fit: cover; }
        
        /* Timeline */
        .timeline-container { position: relative; padding-left: 32px; margin-top: 24px; }
        .timeline-container::before { content: ''; position: absolute; left: 11px; top: 12px; bottom: 12px; width: 2px; background: var(--border); }
        .timeline-item { position: relative; margin-bottom: 32px; }
        .timeline-item:last-child { margin-bottom: 0; }
        
        .timeline-dot { position: absolute; left: -32px; top: 0; width: 24px; height: 24px; border-radius: 50%; background: var(--bg-body); border: 2px solid var(--border); display: flex; align-items: center; justify-content: center; z-index: 1; }
        .timeline-item.past .timeline-dot { background: var(--primary); border-color: var(--primary); color: white; }
        .timeline-item.active .timeline-dot { border-color: var(--primary); border-width: 3px; box-shadow: 0 0 0 6px var(--primary-glow); }
        .timeline-item.active .timeline-dot::after { content: ''; width: 8px; height: 8px; border-radius: 50%; background: var(--primary); }
        .timeline-item.rejected .timeline-dot { border-color: #ef4444; border-width: 3px; box-shadow: 0 0 0 6px rgba(239,68,68,0.1); }
        .timeline-item.rejected .timeline-dot::after { content: ''; width: 8px; height: 8px; border-radius: 50%; background: #ef4444; }

        .timeline-content { padding-left: 20px; }
        .timeline-title { font-size: 15px; font-weight: 800; color: var(--text-heading); margin-bottom: 4px; }
        .timeline-item.active .timeline-title { color: var(--primary); }
        .timeline-item.rejected .timeline-title { color: #ef4444; }
        .timeline-date { font-size: 13px; color: var(--text-muted); font-weight: 600; margin-bottom: 6px; }
        .timeline-desc { font-size: 14px; color: var(--text-body); line-height: 1.5; }

        .info-box { background: var(--bg-surface-2); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 32px; margin-bottom: 32px; }
        .info-box.highlight { background: var(--primary-glow); border-color: rgba(0, 188, 212, 0.2); }
        
        .rating-box { background: rgba(245, 158, 11, 0.05); border: 1px solid rgba(245, 158, 11, 0.2); border-radius: var(--radius-lg); padding: 32px; margin-top: 40px; text-align: center; }
        .star-grp { display: flex; flex-direction: row-reverse; justify-content: center; gap: 12px; margin: 24px 0; }
        .star-lbl { color: #e2e8f0; cursor: pointer; transition: transform 0.2s; }
        .star-lbl:hover { transform: scale(1.1); }
        .star-lbl:hover, .star-lbl:hover ~ .star-lbl, input[type="radio"]:checked ~ .star-lbl { color: #f59e0b; }
        
        .btn-back { display: inline-flex; align-items: center; gap: 8px; font-size: 14px; font-weight: 700; color: var(--text-muted); text-transform: uppercase; letter-spacing: 0.05em; margin-bottom: 24px; transition: var(--transition); text-decoration: none; }
        .btn-back:hover { color: var(--primary); transform: translateX(-4px); }
    </style>
}

<div class="page-wrapper">
    <div class="section-container">
        <a asp-controller="Home" asp-action="Index" class="btn-back">
            <i class="bi bi-arrow-left"></i> Back to Dashboard
        </a>

        <div class="issue-hero">
            <div class="issue-meta-tags">
                <span class="meta-tag status-@Model.Status.ToLower()">@Model.Status</span>
                <span class="meta-tag id">ISS-@Model.IssueId.ToString("D3")</span>
            </div>
            
            <h1 class="issue-details-title">@Model.Title</h1>
            
            <div class="issue-hero-info">
                <div class="hero-info-item">
                    <i class="bi bi-calendar3"></i>
                    <span>Submitted on<br/><strong>@Model.SubmittedAt.ToString("MMM dd, yyyy")</strong></span>
                </div>
                <div class="hero-info-item">
                    <i class="bi bi-tag-fill"></i>
                    <span>Category<br/><strong>@Model.Category</strong></span>
                </div>
                <div class="hero-info-item">
                    <i class="bi bi-geo-alt-fill"></i>
                    <span>Location<br/><strong>@Model.Location</strong></span>
                </div>
            </div>
        </div>

        <div class="row g-5">
            <div class="col-lg-8">
                <div class="card-fixit p-4 p-md-5 mb-4">
                    <div class="section-header-line">
                        <i class="bi bi-card-text"></i>
                        <h3>Issue Description</h3>
                    </div>
                    <p class="desc-text">@Model.Description</p>
                    
                    @if (!string.IsNullOrEmpty(Model.ImageUrl))
                    {
                        <img class="issue-image mb-5" src="@Model.ImageUrl" alt="Issue Image" />
                    }

                    @if (Model.Schedule != null)
                    {
                        <div class="info-box highlight">
                            <div class="section-header-line">
                                <i class="bi bi-tools"></i>
                                <h3>Maintenance Scheduled</h3>
                            </div>
                            <div class="row g-4">
                                <div class="col-sm-6">
                                    <div class="small fw-bold text-uppercase text-muted mb-1">Visit Date</div>
                                    <div class="fs-6 fw-bold">@Model.Schedule.VisitDate.ToString("MMMM dd, yyyy h:mm tt")</div>
                                </div>
                                <div class="col-sm-6">
                                    <div class="small fw-bold text-uppercase text-muted mb-1">Assigned Worker</div>
                                    <div class="fs-6 fw-bold">@Model.Schedule.WorkerName</div>
                                </div>
                            </div>
                        </div>
                    }

                    @if (Model.Report != null)
                    {
                        <div class="info-box">
                            <div class="section-header-line">
                                <i class="bi bi-check-circle-fill text-success"></i>
                                <h3>Completion Report</h3>
                            </div>
                            <div class="mb-4">
                                <div class="small fw-bold text-uppercase text-muted mb-2">Summary of Work</div>
                                <p class="desc-text mb-0">@Model.Report.Summary</p>
                            </div>
                            
                            @if (!string.IsNullOrEmpty(Model.Report.WorkerNotes))
                            {
                                <div class="mb-4">
                                    <div class="small fw-bold text-uppercase text-muted mb-2">Worker Notes</div>
                                    <p class="desc-text mb-0">@Model.Report.WorkerNotes</p>
                                </div>
                            }

                            @if (!string.IsNullOrEmpty(Model.Report.BeforeImageUrl) || !string.IsNullOrEmpty(Model.Report.AfterImageUrl))
                            {
                                <div class="row g-3 mt-4">
                                    @if (!string.IsNullOrEmpty(Model.Report.BeforeImageUrl))
                                    {
                                        <div class="col-sm-6">
                                            <div class="small fw-bold text-uppercase text-muted mb-2 text-center">Before</div>
                                            <img class="issue-image" src="@Model.Report.BeforeImageUrl" alt="Before" style="max-height: 250px;" />
                                        </div>
                                    }
                                    @if (!string.IsNullOrEmpty(Model.Report.AfterImageUrl))
                                    {
                                        <div class="col-sm-6">
                                            <div class="small fw-bold text-uppercase text-muted mb-2 text-center">After</div>
                                            <img class="issue-image" src="@Model.Report.AfterImageUrl" alt="After" style="max-height: 250px;" />
                                        </div>
                                    }
                                </div>
                            }
                        </div>
                    }
                </div>

                <!-- Two-Way Communication -->
                <div class="card-fixit p-4 p-md-5 mb-4">
                    <div class="section-header-line">
                        <i class="bi bi-chat-dots-fill"></i>
                        <h3>Two-Way Communication</h3>
                    </div>
                    
                    <div style="display: flex; flex-direction: column; gap: 16px; margin-bottom: 24px; max-height: 400px; overflow-y: auto; padding-right: 8px;">
                        @if (Model.Comments == null || !Model.Comments.Any())
                        {
                            <div style="text-align: center; color: var(--text-muted); font-size: 14px; padding: 20px;">
                                No comments yet. You can leave a message for the administration here.
                            </div>
                        }
                        else
                        {
                            foreach (var comment in Model.Comments.OrderBy(c => c.CreatedAt))
                            {
                                bool isMyComment = comment.UserId == User.FindFirstValue(System.Security.Claims.ClaimTypes.NameIdentifier);
                                <div style="display: flex; gap: 12px; width: 100%; justify-content: @(isMyComment ? "flex-end" : "flex-start");">
                                    @if (!isMyComment)
                                    {
                                        @if (string.IsNullOrWhiteSpace(comment.UserProfileImageUrl))
                                        {
                                            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--bg-surface-2); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--text-heading); flex-shrink: 0;">
                                                @(string.IsNullOrWhiteSpace(comment.UserName) ? "?" : comment.UserName[0].ToString().ToUpper())
                                            </div>
                                        }
                                        else
                                        {
                                            <img src="@comment.UserProfileImageUrl" alt="@comment.UserName" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
                                            <div class="d-none" style="width: 36px; height: 36px; border-radius: 50%; background: var(--bg-surface-2); border: 1.5px solid var(--border); display: flex; align-items: center; justify-content: center; font-weight: 600; color: var(--text-heading); flex-shrink: 0;">
                                                @(string.IsNullOrWhiteSpace(comment.UserName) ? "?" : comment.UserName[0].ToString().ToUpper())
                                            </div>
                                        }
                                    }
                                    
                                    <div style="background: @(isMyComment ? "var(--primary-glow)" : "var(--bg-surface-2)"); padding: 12px 16px; border-radius: 12px; border: 1px solid @(isMyComment ? "var(--primary)" : "var(--border)"); max-width: 80%;">
                                        <div style="display: flex; justify-content: space-between; gap: 16px; margin-bottom: 4px;">
                                            <strong style="font-size: 13px; color: var(--text-heading);">@(isMyComment ? "You" : comment.UserName + " (Admin)")</strong>
                                            <span style="font-size: 11px; color: var(--text-muted);">@comment.CreatedAt.ToString("MMM d, h:mm tt")</span>
                                        </div>
                                        <p style="margin: 0; font-size: 14px; color: var(--text-body); line-height: 1.5;">@comment.Text</p>
                                    </div>

                                    @if (isMyComment)
                                    {
                                        @if (string.IsNullOrWhiteSpace(comment.UserProfileImageUrl))
                                        {
                                            <div style="width: 36px; height: 36px; border-radius: 50%; background: var(--primary); border: 1.5px solid var(--primary-dark); display: flex; align-items: center; justify-content: center; font-weight: 600; color: #fff; flex-shrink: 0;">
                                                @(string.IsNullOrWhiteSpace(comment.UserName) ? "U" : comment.UserName[0].ToString().ToUpper())
                                            </div>
                                        }
                                        else
                                        {
                                            <img src="@comment.UserProfileImageUrl" alt="@comment.UserName" style="width: 36px; height: 36px; border-radius: 50%; object-fit: cover; flex-shrink: 0;" onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
                                            <div class="d-none" style="width: 36px; height: 36px; border-radius: 50%; background: var(--primary); border: 1.5px solid var(--primary-dark); display: flex; align-items: center; justify-content: center; font-weight: 600; color: #fff; flex-shrink: 0;">
                                                @(string.IsNullOrWhiteSpace(comment.UserName) ? "U" : comment.UserName[0].ToString().ToUpper())
                                            </div>
                                        }
                                    }
                                </div>
                            }
                        }
                    </div>

                    <form asp-controller="Issue" asp-action="AddComment" method="post">
                        @Html.AntiForgeryToken()
                        <input type="hidden" name="IssueId" value="@Model.IssueId" />
                        <textarea name="Text" class="form-control mb-3" placeholder="Type a message..." required style="min-height: 80px; border-radius: var(--radius-md); padding: 12px; font-size: 14px; resize: vertical; border: 1px solid var(--border);"></textarea>
                        <button type="submit" class="btn btn-primary" style="font-weight: 600; border-radius: var(--radius-md); padding: 10px 20px;">
                            <i class="bi bi-send-fill me-2"></i> Send Message
                        </button>
                    </form>
                </div>
            </div>

            <div class="col-lg-4">
                <div class="card-fixit p-4 p-md-5 sticky-top" style="top: 100px;">
                    <div class="section-header-line">
                        <i class="bi bi-clock-history"></i>
                        <h3>Status Tracker</h3>
                    </div>
                    
                    <div class="timeline-container">
                        @if (isRejected)
                        {
                            <div class="timeline-item past">
                                <div class="timeline-dot"><i class="bi bi-check"></i></div>
                                <div class="timeline-content">
                                    <div class="timeline-title">New</div>
                                    <div class="timeline-date">@Model.SubmittedAt.ToString("MMM dd, yyyy h:mm tt")</div>
                                    <div class="timeline-desc">Issue submitted successfully</div>
                                </div>
                            </div>
                            <div class="timeline-item rejected">
                                <div class="timeline-dot"></div>
                                <div class="timeline-content">
                                    <div class="timeline-title">Rejected</div>
                                    <div class="timeline-date">@Model.UpdatedAt.ToString("MMM dd, yyyy h:mm tt")</div>
                                    <div class="timeline-desc">Issue was rejected by administration</div>
                                </div>
                            </div>
                        }
                        else
                        {
                            var orderedStatuses = statuses.OrderBy(s => GetWeight(s.Key)).ToList();
                            bool foundActive = false;
                            
                            foreach (var stage in orderedStatuses)
                            {
                                int stageWeight = GetWeight(stage.Key);
                                bool isActive = currentWeight == stageWeight;
                                bool isPast = currentWeight > stageWeight;
                                
                                if (!isActive && !isPast) continue;
                                
                                string cls = isActive && !foundActive ? "timeline-item active" : "timeline-item past";
                                if (isActive) foundActive = true;
                                
                                DateTime? stageDate = null;
                                if (stage.Key == "New") stageDate = Model.SubmittedAt;
                                else if (stage.Key == "Scheduled" && Model.Schedule != null) stageDate = Model.Schedule.VisitDate;
                                else if (stage.Key == "Resolved" && Model.Report != null) stageDate = Model.Report.SubmittedAt;
                                else if (stageWeight == currentWeight) stageDate = Model.UpdatedAt;

                                <div class="@cls">
                                    <div class="timeline-dot">
                                        @if(isPast) { <i class="bi bi-check"></i> }
                                    </div>
                                    <div class="timeline-content">
                                        <div class="timeline-title">@stage.Display</div>
                                        @if (stageDate.HasValue)
                                        {
                                            <div class="timeline-date">@stageDate.Value.ToString("MMM dd, yyyy h:mm tt")</div>
                                        }
                                        <div class="timeline-desc">@stage.Desc</div>
                                    </div>
                                </div>
                            }
                        }
                    </div>

                    @if (Model.Status == "Resolved" && Model.Rating == null)
                    {
                        <div class="rating-box">
                            <div class="section-header-line">
                                <i class="bi bi-star-fill text-warning"></i>
                                <h3>Rate Resolution</h3>
                            </div>
                            <form asp-controller="Rating" asp-action="Create" method="post">
                                <input type="hidden" name="IssueId" value="@Model.IssueId" />
                                
                                <div class="star-grp">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" id="star@(i)" name="Stars" value="@i" required style="display: none;" />
                                        <label for="star@(i)" class="star-lbl">
                                            <i class="bi bi-star-fill fs-3"></i>
                                        </label>
                                    }
                                </div>

                                <textarea name="Comment" class="form-control-fixit mb-3" rows="3" placeholder="Add a comment (optional)"></textarea>
                                
                                <button type="submit" class="btn-primary-fixit w-100">Submit Feedback</button>
                            </form>
                        </div>
                    }
                    else if (Model.Rating != null)
                    {
                        <div class="rating-box">
                            <div class="section-header-line">
                                <i class="bi bi-star-fill text-warning"></i>
                                <h3>Your Feedback</h3>
                            </div>
                            <div class="d-flex align-items-center gap-2 mb-3">
                                <div class="fs-1 fw-bold text-warning">@Model.Rating.Stars</div>
                                <div class="text-warning fs-4">
                                    @for (int i = 1; i <= 5; i++)
                                    {
                                        <i class="bi @(i <= Model.Rating.Stars ? "bi-star-fill" : "bi-star")"></i>
                                    }
                                </div>
                            </div>
                            @if (!string.IsNullOrEmpty(Model.Rating.Comment))
                            {
                                <p class="fst-italic text-muted mb-0">"@Model.Rating.Comment"</p>
                            }
                        </div>
                    }
                </div>
            </div>
        </div>
    </div>
</div>
