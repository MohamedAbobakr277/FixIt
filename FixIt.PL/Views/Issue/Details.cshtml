@model FixIt.Common.DTOs.IssueDetailsDto
@{
    ViewData["Title"] = $"Issue #{Model.IssueId} - {Model.Title}";
}

<!-- ══ HEADER ══ -->
<section class="section section-white">
    <div class="section-container">
        <div class="issue-header">
            <div class="issue-header-left">
                <a asp-controller="Home" asp-action="Index" class="back-link">← Back to Home</a>
                <h1 class="issue-title">@Model.Title</h1>
                <div class="issue-meta">
                    <span class="issue-meta-item">📍 @Model.Location</span>
                    <span class="issue-meta-item">👤 @Model.CitizenName</span>
                    <span class="issue-meta-item">📅 @Model.SubmittedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
            <div class="issue-header-right">
                <span class="status-badge status-@Model.Status.ToLower()">@Model.Status</span>
                <span class="priority-badge priority-@Model.Priority.ToLower()">@Model.Priority</span>
            </div>
        </div>
    </div>
</section>

<!-- ══ INFO CARD ══ -->
<section class="section section-alt">
    <div class="section-container">
        <div class="details-grid">
            <div class="details-card">
                <h2 class="details-card-title">Issue Information</h2>
                <div class="details-content">
                    <div class="detail-row">
                        <span class="detail-label">Category</span>
                        <span class="detail-value">@Model.Category</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Status</span>
                        <span class="detail-value">@Model.Status</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Priority</span>
                        <span class="detail-value">@Model.Priority</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Submitted</span>
                        <span class="detail-value">@Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Last Updated</span>
                        <span class="detail-value">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="details-card">
                    <h2 class="details-card-title">Issue Image</h2>
                    <div class="details-image">
                        <img src="@Model.ImageUrl" alt="Issue image" />
                    </div>
                </div>
            }
        </div>

        <div class="details-card details-full">
            <h2 class="details-card-title">Description</h2>
            <p class="details-description">@Model.Description</p>
            @if (!string.IsNullOrEmpty(Model.AdminNotes))
            {
                <div class="admin-notes">
                    <strong>Admin Notes:</strong>
                    <p>@Model.AdminNotes</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ STATUS TIMELINE ══ -->
<section class="section section-white">
    <div class="section-container">
        <h2 class="section-title">Status Timeline</h2>
        <div class="timeline">
            <div class="timeline-item timeline-active">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-status">New</div>
                    <div class="timeline-date">@Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</div>
                    <div class="timeline-desc">Issue submitted successfully</div>
                </div>
            </div>
            @if (Model.Status != "New")
            {
                <div class="timeline-item @(Model.Status == "In Progress" || Model.Status == "Scheduled" || Model.Status == "Resolved" ? "timeline-active" : "")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">In Progress</div>
                        <div class="timeline-date">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Issue is being reviewed</div>
                    </div>
                </div>
            }
            @if (Model.Schedule != null)
            {
                <div class="timeline-item @(Model.Status == "Scheduled" || Model.Status == "Resolved" ? "timeline-active" : "")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">Scheduled</div>
                        <div class="timeline-date">@Model.Schedule.VisitDate.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Maintenance scheduled for @Model.Schedule.WorkerName</div>
                    </div>
                </div>
            }
            @if (Model.Status == "Resolved")
            {
                <div class="timeline-item timeline-active">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">Resolved</div>
                        <div class="timeline-date">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Issue has been resolved</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ SCHEDULE CARD ══ -->
@if (Model.Schedule != null)
{
    <section class="section section-alt">
        <div class="section-container">
            <div class="details-card">
                <h2 class="details-card-title">📅 Maintenance Schedule</h2>
                <div class="schedule-details">
                    <div class="schedule-row">
                        <span class="schedule-label">Visit Date</span>
                        <span class="schedule-value">@Model.Schedule.VisitDate.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="schedule-row">
                        <span class="schedule-label">Estimated Cost</span>
                        <span class="schedule-value">$@Model.Schedule.EstimatedCost.ToString("F2")</span>
                    </div>
                    <div class="schedule-row">
                        <span class="schedule-label">Assigned Worker</span>
                        <span class="schedule-value">@Model.Schedule.WorkerName ?? "TBD"</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ REPORT CARD ══ -->
@if (Model.Report != null)
{
    <section class="section section-white">
        <div class="section-container">
            <div class="details-card">
                <h2 class="details-card-title">📊 Maintenance Report</h2>
                <div class="report-details">
                    <div class="report-summary">
                        <strong>Summary:</strong>
                        <p>@Model.Report.Summary</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Report.WorkerNotes))
                    {
                        <div class="report-notes">
                            <strong>Worker Notes:</strong>
                            <p>@Model.Report.WorkerNotes</p>
                        </div>
                    }
                    <div class="report-images">
                        @if (!string.IsNullOrEmpty(Model.Report.BeforeImageUrl))
                        {
                            <div class="report-image">
                                <span class="report-image-label">Before</span>
                                <img src="@Model.Report.BeforeImageUrl" alt="Before maintenance" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Report.AfterImageUrl))
                        {
                            <div class="report-image">
                                <span class="report-image-label">After</span>
                                <img src="@Model.Report.AfterImageUrl" alt="After maintenance" />
                            </div>
                        }
                    </div>
                    <div class="report-date">
                        <small>Submitted on @Model.Report.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</small>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ RATING SECTION ══ -->
@if (Model.Rating != null)
{
    <section class="section section-alt">
        <div class="section-container">
            <div class="details-card">
                <h2 class="details-card-title">⭐ Service Rating</h2>
                <div class="rating-details">
                    <div class="rating-stars">
                        @for (int i = 1; i <= 5; i++)
                        {
                            <span class="star @(i <= Model.Rating.Stars ? "star-filled" : "star-empty")">★</span>
                        }
                    </div>
                    <div class="rating-value">@Model.Rating.Stars out of 5</div>
                    @if (!string.IsNullOrEmpty(Model.Rating.Comment))
                    {
                        <div class="rating-comment">
                            <strong>Comment:</strong>
                            <p>@Model.Rating.Comment</p>
                        </div>
                    }
                    <div class="rating-date">
                        <small>Rated on @Model.Rating.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</small>
                    </div>
                </div>
            </div>
        </div>
    </section>
}
