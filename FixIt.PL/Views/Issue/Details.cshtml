@model FixIt.Common.DTOs.IssueDetailsDto
@{
    ViewData["Title"] = $"Issue #{Model.IssueId} - {Model.Title}";
}

<!-- ══ HEADER ══ -->
<section class="section section-white">
    <div class="section-container">
        <div class="issue-header">
            <div class="issue-header-left">
                <a asp-controller="Home" asp-action="Index" class="back-link">← Back to Home</a>
                <h1 class="issue-title">@Model.Title</h1>
                <div class="issue-meta">
                    <span class="issue-meta-item">📍 @Model.Location</span>
                    <span class="issue-meta-item">👤 @Model.CitizenName</span>
                    <span class="issue-meta-item">📅 @Model.SubmittedAt.ToString("MMM dd, yyyy")</span>
                </div>
            </div>
            <div class="issue-header-right">
                <span class="status-badge status-@Model.Status.ToLower()">@Model.Status</span>
                <span class="priority-badge priority-@Model.Priority.ToLower()">@Model.Priority</span>
            </div>
        </div>
    </div>
</section>

<!-- ══ INFO CARD ══ -->
<section class="section section-alt">
    <div class="section-container">
        <div class="details-grid">
            <div class="details-card">
                <h2 class="details-card-title">Issue Information</h2>
                <div class="details-content">
                    <div class="detail-row">
                        <span class="detail-label">Category</span>
                        <span class="detail-value">@Model.Category</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Status</span>
                        <span class="detail-value">@Model.Status</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Priority</span>
                        <span class="detail-value">@Model.Priority</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Submitted</span>
                        <span class="detail-value">@Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="detail-row">
                        <span class="detail-label">Last Updated</span>
                        <span class="detail-value">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                </div>
            </div>

            @if (!string.IsNullOrEmpty(Model.ImageUrl))
            {
                <div class="details-card">
                    <h2 class="details-card-title">Issue Image</h2>
                    <div class="details-image">
                        <img src="@Model.ImageUrl" alt="Issue image" />
                    </div>
                </div>
            }
        </div>

        <div class="details-card details-full">
            <h2 class="details-card-title">Description</h2>
            <p class="details-description">@Model.Description</p>
            @if (!string.IsNullOrEmpty(Model.AdminNotes))
            {
                <div class="admin-notes">
                    <strong>Admin Notes:</strong>
                    <p>@Model.AdminNotes</p>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ STATUS TIMELINE ══ -->
<section class="section section-white">
    <div class="section-container">
        <h2 class="section-title">Status Timeline</h2>
        <div class="timeline">
            <div class="timeline-item timeline-active">
                <div class="timeline-dot"></div>
                <div class="timeline-content">
                    <div class="timeline-status">New</div>
                    <div class="timeline-date">@Model.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</div>
                    <div class="timeline-desc">Issue submitted successfully</div>
                </div>
            </div>
            @if (Model.Status != "New")
            {
                <div class="timeline-item @(Model.Status == "In Progress" || Model.Status == "Scheduled" || Model.Status == "Resolved" ? "timeline-active" : "")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">In Progress</div>
                        <div class="timeline-date">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Issue is being reviewed</div>
                    </div>
                </div>
            }
            @if (Model.Schedule != null)
            {
                <div class="timeline-item @(Model.Status == "Scheduled" || Model.Status == "Resolved" ? "timeline-active" : "")">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">Scheduled</div>
                        <div class="timeline-date">@Model.Schedule.VisitDate.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Maintenance scheduled for @Model.Schedule.WorkerName</div>
                    </div>
                </div>
            }
            @if (Model.Status == "Resolved")
            {
                <div class="timeline-item timeline-active">
                    <div class="timeline-dot"></div>
                    <div class="timeline-content">
                        <div class="timeline-status">Resolved</div>
                        <div class="timeline-date">@Model.UpdatedAt.ToString("MMM dd, yyyy HH:mm")</div>
                        <div class="timeline-desc">Issue has been resolved</div>
                    </div>
                </div>
            }
        </div>
    </div>
</section>

<!-- ══ SCHEDULE CARD ══ -->
@if (Model.Schedule != null)
{
    <section class="section section-alt">
        <div class="section-container">
            <div class="details-card">
                <h2 class="details-card-title">📅 Maintenance Schedule</h2>
                <div class="schedule-details">
                    <div class="schedule-row">
                        <span class="schedule-label">Visit Date</span>
                        <span class="schedule-value">@Model.Schedule.VisitDate.ToString("MMM dd, yyyy HH:mm")</span>
                    </div>
                    <div class="schedule-row">
                        <span class="schedule-label">Estimated Cost</span>
                        <span class="schedule-value">$@Model.Schedule.EstimatedCost.ToString("F2")</span>
                    </div>
                    <div class="schedule-row">
                        <span class="schedule-label">Assigned Worker</span>
                        <span class="schedule-value">@Model.Schedule.WorkerName</span>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ REPORT CARD ══ -->
@if (Model.Report != null)
{
    <section class="section section-white">
        <div class="section-container">
            <div class="details-card">
                <h2 class="details-card-title">📊 Maintenance Report</h2>
                <div class="report-details">
                    <div class="report-summary">
                        <strong>Summary:</strong>
                        <p>@Model.Report.Summary</p>
                    </div>
                    @if (!string.IsNullOrEmpty(Model.Report.WorkerNotes))
                    {
                        <div class="report-notes">
                            <strong>Worker Notes:</strong>
                            <p>@Model.Report.WorkerNotes</p>
                        </div>
                    }
                    <div class="report-images">
                        @if (!string.IsNullOrEmpty(Model.Report.BeforeImageUrl))
                        {
                            <div class="report-image">
                                <span class="report-image-label">Before</span>
                                <img src="@Model.Report.BeforeImageUrl" alt="Before maintenance" />
                            </div>
                        }
                        @if (!string.IsNullOrEmpty(Model.Report.AfterImageUrl))
                        {
                            <div class="report-image">
                                <span class="report-image-label">After</span>
                                <img src="@Model.Report.AfterImageUrl" alt="After maintenance" />
                            </div>
                        }
                    </div>
                    <div class="report-date">
                        <small>Submitted on @Model.Report.SubmittedAt.ToString("MMM dd, yyyy HH:mm")</small>
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<!-- ══ RATE THIS RESOLUTION (IN-PAGE FORM) ══ -->
@if (Model.Status == "Resolved" && Model.Rating == null)
{
    <section class="section section-alt pt-0">
        <div class="section-container">
            <div class="card-fixit p-4 p-md-5">
                <div class="row">
                    <div class="col-lg-7">
                        <div class="section-label mb-3">Feedback</div>
                        <h2 class="section-title mb-2">Rate This Resolution</h2>
                        <p class="text-muted mb-4">Help us improve by rating the quality of this resolution</p>

                        <form asp-controller="Rating" asp-action="Create" method="post">
                            <input type="hidden" name="IssueId" value="@Model.IssueId" />
                            
                            <div class="mb-4">
                                <label class="form-label-fixit fs-6 mb-3">Your rating:</label>
                                <div class="stars-input-container d-flex flex-row-reverse justify-content-start gap-2">
                                    @for (int i = 5; i >= 1; i--)
                                    {
                                        <input type="radio" id="detailStar@(i)" name="Stars" value="@i" required class="d-none peer" />
                                        <label for="detailStar@(i)" class="star-btn cursor-pointer">
                                            <svg width="32" height="32" viewBox="0 0 24 24" fill="currentColor"><path d="M12 17.27L18.18 21l-1.64-7.03L22 9.24l-7.19-.61L12 2 9.19 8.63 2 9.24l5.46 4.73L5.82 21z" /></svg>
                                        </label>
                                    }
                                </div>
                            </div>

                            <div class="mb-4">
                                <textarea name="Comment" class="form-control-fixit" rows="3" placeholder="Add a comment (optional)"></textarea>
                            </div>

                            <button type="submit" class="btn-primary-fixit">
                                Submit Rating
                            </button>
                        </form>
                    </div>
                </div>
            </div>
        </div>
    </section>
}


<!-- ══ RATING SECTION ══ -->
@if (Model.Rating != null)
{
    <section class="section section-alt">
        <div class="section-container">
            <div class="card-fixit border-0 overflow-hidden" style="background: linear-gradient(135deg, var(--bg-card) 0%, var(--bg-surface-2) 100%);">
                <div class="row align-items-center">
                    <div class="col-md-4 text-center border-end-md py-4">
                        <div class="section-label mb-2">Resolution Rating</div>
                        <div class="display-3 fw-900 text-primary mb-0">@Model.Rating.Stars</div>
                        <div class="text-warning fs-4 mb-2">
                            @for (int i = 1; i <= 5; i++)
                            {
                                <span>@(i <= Model.Rating.Stars ? "★" : "☆")</span>
                            }
                        </div>
                        <div class="text-muted small">Submitted on @Model.Rating.SubmittedAt.ToString("MMM dd, yyyy")</div>
                    </div>
                    <div class="col-md-8 p-5">
                        <div class="d-flex align-items-center gap-3 mb-4">
                            <div class="nav-brand-icon" style="width: 48px; height: 48px; font-size: 20px;">
                                @(Model.CitizenName.Length > 0 ? Model.CitizenName[0].ToString().ToUpper() : "C")
                            </div>
                            <div>
                                <h4 class="mb-0 fw-bold">@Model.CitizenName</h4>
                                <p class="text-muted small mb-0">Verified Citizen Feedback</p>
                            </div>
                        </div>
                        
                        @if (!string.IsNullOrEmpty(Model.Rating.Comment))
                        {
                            <div class="position-relative">
                                <svg width="40" height="40" viewBox="0 0 24 24" fill="currentColor" class="text-primary opacity-10 position-absolute" style="top: -20px; left: -10px;">
                                    <path d="M14.017 21L14.017 18C14.017 16.8954 14.9124 16 16.017 16H19.017C20.1216 16 21.017 16.8954 21.017 18V21C21.017 22.1046 20.1216 23 19.017 23H16.017C14.9124 23 14.017 22.1046 14.017 21ZM14.017 21C14.017 19.8954 13.1216 19 12.017 19H9.017C7.91242 19 7.017 19.8954 7.017 21V23C7.017 23.5523 6.56929 24 6.017 24H3.017C1.91243 24 1.017 23.1046 1.017 22V19C1.017 17.8954 1.91243 17 3.017 17H6.017C7.12157 17 8.017 17.8954 8.017 19V21M14.017 21L14.017 21Z" />
                                </svg>
                                <p class="fs-5 fst-italic text-body ps-4 position-relative z-1" style="line-height: 1.6;">
                                    "@Model.Rating.Comment"
                                </p>
                            </div>
                        }
                        else
                        {
                            <p class="text-muted fst-italic">No comment provided.</p>
                        }
                    </div>
                </div>
            </div>
        </div>
    </section>
}

<style>
    .star-btn {
        color: var(--border);
        transition: all 0.2s ease;
    }
    
    .star-btn:hover {
        transform: scale(1.1);
        color: #fbbf24;
    }

    input[type="radio"]:checked ~ .star-btn,
    .star-btn:hover ~ .star-btn {
        color: #fbbf24;
    }

    .fw-900 { font-weight: 900; }
    @@media (min-width: 768px) {
        .border-end-md { border-right: 1px solid var(--border); }
    }
</style>
