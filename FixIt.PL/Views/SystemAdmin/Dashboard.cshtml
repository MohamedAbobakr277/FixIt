@model FixIt.BLL.DTOs.SystemDashboardStatsDto
@{
    ViewData["Title"] = "System Administration";
}

<div class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-5">
        <div>
            <h1 class="fw-bold" style="color: var(--text-heading); font-size: 2.2rem; margin-bottom: 0;">
                System Overview
            </h1>
            <p class="text-muted mt-2" style="font-size: 1.1rem;">High-level metrics and system health indicators.</p>
        </div>
        <a asp-action="Users" class="btn btn-primary-fixit">
            <i class="bi bi-people me-2"></i> Manage Users
        </a>
    </div>

    <!-- Metrics Grid -->
    <div class="row g-4 mb-5">
        
        <!-- Total Users Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #10b981 0%, #059669 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-people" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                    <div>
                        <h2 class="display-5 fw-bold mb-0">@Model.TotalUsers</h2>
                        <span style="opacity: 0.9; font-weight: 500;">Total Registered Users</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Role Breakdown Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: var(--bg-surface);">
                <div class="card-body p-4">
                    <h5 class="fw-bold mb-4" style="color: var(--text-heading);">Role Breakdown</h5>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="bi bi-person me-2 text-primary"></i> Citizens</span>
                        <span class="fw-bold">@Model.TotalCitizens</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center mb-3">
                        <span class="text-muted"><i class="bi bi-shield-lock me-2 text-warning"></i> Admins</span>
                        <span class="fw-bold">@Model.TotalAdmins</span>
                    </div>
                    <div class="d-flex justify-content-between align-items-center">
                        <span class="text-muted"><i class="bi bi-hdd-network me-2 text-danger"></i> System Admins</span>
                        <span class="fw-bold">@Model.TotalSystemAdmins</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Active Issues Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: linear-gradient(135deg, #f59e0b 0%, #d97706 100%); color: white;">
                <div class="card-body p-4 d-flex flex-column justify-content-between">
                    <div class="d-flex justify-content-between align-items-start mb-3">
                        <div style="background: rgba(255,255,255,0.2); border-radius: 12px; width: 48px; height: 48px; display: flex; align-items: center; justify-content: center;">
                            <i class="bi bi-exclamation-triangle" style="font-size: 1.5rem;"></i>
                        </div>
                    </div>
                    <div>
                        <h2 class="display-5 fw-bold mb-0">@Model.ActiveIssues</h2>
                        <span style="opacity: 0.9; font-weight: 500;">Active Issues</span>
                    </div>
                </div>
            </div>
        </div>

        <!-- Resolved Issues Card -->
        <div class="col-md-3">
            <div class="card border-0 shadow-sm rounded-4 h-100" style="background: var(--bg-surface);">
                <div class="card-body p-4 d-flex flex-column justify-content-center text-center">
                    <h5 class="fw-bold mb-3" style="color: var(--text-heading);">Overall Resolution</h5>
                    <div class="mb-3">
                        <i class="bi bi-check-circle text-success" style="font-size: 3rem;"></i>
                    </div>
                    <h3 class="fw-bold text-success mb-1">@Model.ResolvedIssues</h3>
                    <span class="text-muted">Total Issues Resolved</span>
                </div>
            </div>
        </div>
    </div>
</div>
