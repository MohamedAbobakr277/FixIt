@model IEnumerable<FixIt.BLL.DTOs.UserManagementDto>
@{
    ViewData["Title"] = "Manage Users";
}

<div class="container py-5 mt-5">
    <div class="d-flex justify-content-between align-items-center mb-4">
        <div>
            <h1 class="fw-bold" style="color: var(--text-heading); font-size: 2.2rem; margin-bottom: 0;">
                User Management
            </h1>
            <p class="text-muted mt-2" style="font-size: 1.1rem;">Manage roles, access, and permissions for all users.</p>
        </div>
        <a asp-action="Dashboard" class="btn btn-outline-secondary">
            <i class="bi bi-arrow-left me-2"></i> Back to Dashboard
        </a>
    </div>

    @if (TempData["ErrorMessage"] != null)
    {
        <div class="alert alert-danger shadow-sm rounded-4 mb-4">
            <i class="bi bi-exclamation-octagon-fill me-2"></i> @TempData["ErrorMessage"]
        </div>
    }

    <div class="card border-0 shadow-sm rounded-4" style="background: var(--bg-surface); overflow: hidden;">
        <div class="card-body p-0">
            <div class="table-responsive">
                <table class="table table-hover align-middle mb-0" style="color: var(--text-body);">
                    <thead style="background: rgba(0,0,0,0.03);">
                        <tr>
                            <th class="ps-4 py-3 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">User</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">Email</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">Role</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">Status</th>
                            <th class="py-3 text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">Joined</th>
                            <th class="pe-4 py-3 text-end text-uppercase text-muted" style="font-size: 0.85rem; font-weight: 600;">Actions</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var user in Model)
                        {
                            <tr>
                                <td class="ps-4 py-3">
                                    <div class="d-flex align-items-center">
                                        <div style="width: 40px; height: 40px; background: var(--primary-color); color: white; border-radius: 50%; display: flex; align-items: center; justify-content: center; font-weight: bold; margin-right: 12px;">
                                            @(string.IsNullOrEmpty(user.FullName) ? "U" : user.FullName[0].ToString().ToUpper())
                                        </div>
                                        <div>
                                            <div class="fw-bold" style="color: var(--text-heading);">@user.FullName</div>
                                            <div class="text-muted" style="font-size: 0.85rem;">@user.Id.Substring(0, 8)...</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-3">@user.Email</td>
                                <td class="py-3">
                                    @if (user.Role == "SystemAdmin")
                                    {
                                        <span class="badge bg-danger bg-opacity-10 text-danger border border-danger border-opacity-25 rounded-pill px-3 py-2">System Admin</span>
                                    }
                                    else if (user.Role == "Admin")
                                    {
                                        <span class="badge bg-warning bg-opacity-10 text-warning border border-warning border-opacity-25 rounded-pill px-3 py-2">Admin</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-primary bg-opacity-10 text-primary border border-primary border-opacity-25 rounded-pill px-3 py-2">Citizen</span>
                                    }
                                </td>
                                <td class="py-3">
                                    @if (user.IsLockedOut)
                                    {
                                        <span class="badge bg-secondary bg-opacity-10 text-secondary border border-secondary border-opacity-25 rounded-pill px-3 py-2"><i class="bi bi-lock-fill me-1"></i> Locked</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-success bg-opacity-10 text-success border border-success border-opacity-25 rounded-pill px-3 py-2"><i class="bi bi-unlock-fill me-1"></i> Active</span>
                                    }
                                </td>
                                <td class="py-3 text-muted" style="font-size: 0.95rem;">
                                    @user.CreatedAt.ToString("MMM dd, yyyy")
                                </td>
                                <td class="pe-4 py-3 text-end">
                                    <div class="btn-group">
                                        <button type="button" class="btn btn-sm btn-light border dropdown-toggle" data-bs-toggle="dropdown" aria-expanded="false" style="border-radius: 8px;">
                                            Manage
                                        </button>
                                        <ul class="dropdown-menu dropdown-menu-end shadow border-0" style="border-radius: 12px; min-width: 200px;">
                                            <li><h6 class="dropdown-header text-uppercase text-muted" style="font-size: 0.75rem;">Change Role</h6></li>
                                            
                                            <form asp-action="ChangeRole" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="newRole" value="Citizen" />
                                                <li><button type="submit" class="dropdown-item py-2" @(user.Role == "Citizen" ? "disabled" : "")><i class="bi bi-person me-2"></i> Make Citizen</button></li>
                                            </form>
                                            
                                            <form asp-action="ChangeRole" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="newRole" value="Admin" />
                                                <li><button type="submit" class="dropdown-item py-2" @(user.Role == "Admin" ? "disabled" : "")><i class="bi bi-shield me-2"></i> Make Admin</button></li>
                                            </form>

                                            <form asp-action="ChangeRole" method="post" class="d-inline">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <input type="hidden" name="newRole" value="SystemAdmin" />
                                                <li><button type="submit" class="dropdown-item py-2" @(user.Role == "SystemAdmin" ? "disabled" : "")><i class="bi bi-hdd-network me-2"></i> Make System Admin</button></li>
                                            </form>
                                            
                                            <li><hr class="dropdown-divider"></li>
                                            <li><h6 class="dropdown-header text-uppercase text-muted" style="font-size: 0.75rem;">Access Control</h6></li>
                                            
                                            <form asp-action="ToggleLock" method="post">
                                                <input type="hidden" name="userId" value="@user.Id" />
                                                <li>
                                                    @if (user.IsLockedOut)
                                                    {
                                                        <button type="submit" class="dropdown-item py-2 text-success"><i class="bi bi-unlock-fill me-2"></i> Unlock Account</button>
                                                    }
                                                    else
                                                    {
                                                        <button type="submit" class="dropdown-item py-2 text-danger"><i class="bi bi-lock-fill me-2"></i> Lock Account</button>
                                                    }
                                                </li>
                                            </form>
                                        </ul>
                                    </div>
                                </td>
                            </tr>
                        }
                        
                        @if (!Model.Any())
                        {
                            <tr>
                                <td colspan="6" class="text-center py-5 text-muted">
                                    <i class="bi bi-people" style="font-size: 2.5rem; opacity: 0.5;"></i>
                                    <p class="mt-2 mb-0">No users found.</p>
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>
    </div>
</div>
