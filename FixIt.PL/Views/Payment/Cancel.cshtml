@{
    ViewData["Title"] = "Payment Cancelled";
    var issueId = ViewBag.IssueId;
}

<div class="container" style="margin-top: 130px; margin-bottom: 80px; max-width: 600px;">
    <div class="text-center" style="background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 50px 40px; box-shadow: var(--card-shadow); transition: var(--transition);">
        
        <!-- Cancel warning/alert icon -->
        <div class="cancel-icon-container" style="display: inline-flex; align-items: center; justify-content: center; width: 84px; height: 84px; background: rgba(231, 76, 60, 0.1); color: #e74c3c; border-radius: var(--radius-full); font-size: 42px; margin-bottom: 30px; animation: wobble 0.6s ease;">
            <i class="bi bi-x-circle-fill"></i>
        </div>

        <h1 class="mb-2" style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--text-heading);">Payment Cancelled</h1>
        <p class="mb-4 text-muted" style="font-size: 15px;">Your checkout session was cancelled. No charges were made to your card.</p>

        <div style="background: var(--bg-surface-2); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 20px; text-align: center; margin-bottom: 35px; font-size: 14px; color: var(--text-body);">
            <i class="bi bi-info-circle" style="color: var(--primary); margin-right: 6px;"></i> You can retry the payment at any time from the issue details screen.
        </div>

        <!-- Action buttons -->
        <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
            @if (issueId != null)
            {
                <a href="@Url.Action("Checkout", "Payment", new { id = issueId })" class="btn-primary-fixit" style="text-decoration: none;">
                    <i class="bi bi-credit-card-2-front" style="font-size: 16px;"></i> Retry Payment
                </a>
                <a href="@Url.Action("Details", "Issue", new { id = issueId })" class="btn-outline-fixit" style="text-decoration: none;">
                    View Issue Details
                </a>
            }
            else
            {
                <a href="@Url.Action("Index", "Issue")" class="btn-primary-fixit" style="text-decoration: none;">
                    My Issues List
                </a>
            }
        </div>
    </div>
</div>

<style>
    @@keyframes wobble {
        0%, 100% { transform: translateX(0); }
        15% { transform: translateX(-8px) rotate(-3deg); }
        30% { transform: translateX(6px) rotate(2deg); }
        45% { transform: translateX(-4px) rotate(-1deg); }
        60% { transform: translateX(3px) rotate(1deg); }
        75% { transform: translateX(-2px) rotate(0deg); }
    }
</style>
