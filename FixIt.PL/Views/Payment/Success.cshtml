@model FixIt.BLL.DTOs.PaymentDto

@{
    ViewData["Title"] = "Payment Successful";
}

<div class="container" style="margin-top: 130px; margin-bottom: 80px; max-width: 600px;">
    <div class="text-center" style="background: var(--bg-surface); border: 1px solid var(--border); border-radius: var(--radius-lg); padding: 50px 40px; box-shadow: var(--card-shadow); transition: var(--transition);">
        
        <!-- Animated success check icon -->
        <div class="success-icon-container" style="display: inline-flex; align-items: center; justify-content: center; width: 84px; height: 84px; background: rgba(46, 204, 113, 0.1); color: #2ecc71; border-radius: var(--radius-full); font-size: 42px; margin-bottom: 30px; animation: bounceIn 0.8s cubic-bezier(0.175, 0.885, 0.32, 1.275);">
            <i class="bi bi-check-circle-fill"></i>
        </div>

        <h1 class="mb-2" style="font-family: var(--font-heading); font-size: 32px; font-weight: 800; color: var(--text-heading);">Payment Confirmed!</h1>
        <p class="mb-4 text-muted" style="font-size: 15px;">Your transaction was processed successfully. Thank you for your payment.</p>

        <!-- Payment Details Table/Card -->
        <div class="payment-details-card" style="background: var(--bg-surface-2); border: 1px solid var(--border); border-radius: var(--radius-md); padding: 24px; text-align: left; margin-bottom: 35px;">
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 14px;">
                <span class="text-muted">Issue Reference</span>
                <span style="font-weight: 600; color: var(--text-heading);">#@Model.IssueId</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 14px;">
                <span class="text-muted">Amount Paid</span>
                <span style="font-weight: 700; color: var(--primary-dark); font-size: 16px;">@Model.Amount.ToString("F2") @Model.Currency</span>
            </div>
            <div style="display: flex; justify-content: space-between; margin-bottom: 12px; font-size: 14px;">
                <span class="text-muted">Status</span>
                <span class="badge" style="background: rgba(46, 204, 113, 0.15); color: #2ecc71; font-weight: 600; padding: 4px 10px; border-radius: var(--radius-sm); font-size: 12px;">Completed</span>
            </div>
            <div style="display: flex; justify-content: space-between; font-size: 14px;">
                <span class="text-muted">Payment Date</span>
                <span style="font-weight: 500; color: var(--text-heading);">@(Model.CompletedAt?.ToLocalTime().ToString("g") ?? DateTime.Now.ToString("g"))</span>
            </div>
        </div>

        <!-- Action buttons -->
        <div style="display: flex; gap: 15px; justify-content: center; flex-wrap: wrap;">
            <a href="@Url.Action("Details", "Issue", new { id = Model.IssueId })" class="btn-primary-fixit" style="text-decoration: none;">
                <i class="bi bi-arrow-left-short" style="font-size: 18px;"></i> Back to Issue Details
            </a>
            <a href="@Url.Action("Index", "Issue")" class="btn-outline-fixit" style="text-decoration: none;">
                View All My Issues
            </a>
        </div>
    </div>
</div>

<style>
    @@keyframes bounceIn {
        0% { transform: scale(0.3); opacity: 0; }
        50% { transform: scale(1.05); opacity: 0.8; }
        70% { transform: scale(0.9); opacity: 0.9; }
        100% { transform: scale(1); opacity: 1; }
    }
</style>
