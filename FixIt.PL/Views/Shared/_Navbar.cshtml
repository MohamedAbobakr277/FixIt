@using Microsoft.AspNetCore.Identity
@using FixIt.DAL.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager

<nav class="navbar-fixit" id="mainNavbar">
    <div class="scroll-progress" id="scrollProgress"></div>
    <div class="nav-container">

        <a class="nav-brand" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" asp-append-version="true" alt="FixIt" class="nav-brand-logo" />
            FixIt
        </a>

        <button class="nav-toggle" id="navToggle" aria-label="Toggle navigation">
            <span></span><span></span><span></span>
        </button>

        @{
            var isHome = ViewContext.RouteData.Values["controller"]?.ToString() == "Home" && 
                         ViewContext.RouteData.Values["action"]?.ToString() == "Index";
            string GetLink(string hash) => isHome ? hash : Url.Action("Index", "Home") + hash;
        }
        <ul class="nav-links" id="navLinks">
            @if (SignInManager.IsSignedIn(User))
            {
                @if (User.IsInRole("Admin"))
                {
                    <li><a asp-controller="Admin" asp-action="Dashboard"><i class="bi bi-speedometer2"></i> Admin Dashboard</a></li>
                }
                else
                {
                    var ctrl = ViewContext.RouteData.Values["controller"]?.ToString();
                    var act = ViewContext.RouteData.Values["action"]?.ToString();
                    
                    <li><a asp-controller="Citizen" asp-action="Dashboard" class="@(ctrl == "Citizen" && act == "Dashboard" ? "active" : "")"><i class="bi bi-grid-1x2"></i> Dashboard</a></li>
                    <li><a asp-controller="Issue" asp-action="Create" class="@(ctrl == "Issue" && act == "Create" ? "active" : "")"><i class="bi bi-plus-lg"></i> Report Issue</a></li>
                    <li><a asp-controller="Citizen" asp-action="Profile" class="@(ctrl == "Citizen" && act == "Profile" ? "active" : "")"><i class="bi bi-person-circle"></i> Profile</a></li>
                }
            }
            else
            {
                <li><a href="@GetLink("#features")">Features</a></li>
                <li><a href="@GetLink("#how-it-works")">How It Works</a></li>
                <li><a href="@GetLink("#categories")">Categories</a></li>
            }
        </ul>

        <div class="nav-actions" id="navActions">
            <button class="theme-toggle" id="themeToggle" aria-label="Toggle dark mode" title="Toggle dark mode">
                🌙
            </button>

            @if (SignInManager.IsSignedIn(User))
            {
                var currentUser = await UserManager.GetUserAsync(User);
                var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "User";
                
                <div class="nav-user-info">
                    <div class="nav-user-avatar">
                        <i class="bi bi-person"></i>
                    </div>
                    <span class="nav-user-name">@displayName.ToLower()</span>
                </div>

                <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                    @Html.AntiForgeryToken()
                    <button type="submit" class="nav-logout-minimal" title="Logout">
                        <i class="bi bi-box-arrow-right"></i> Logout
                    </button>
                </form>
            }
            else
            {
                <a class="nav-login" asp-controller="Account" asp-action="Login">Sign In</a>
                <a class="btn-primary-fixit" asp-controller="Account" asp-action="Register">Get Started →</a>
            }
        </div>

    </div>
</nav>