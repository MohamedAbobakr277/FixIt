@using Microsoft.AspNetCore.Identity
@using FixIt.DAL.Entities
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
<!DOCTYPE html>
<html lang="en" data-adm-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FixIt Admin — Manage and oversee community issue reports." />
    <title>@ViewData["Title"] - FixIt Admin</title>
    <link rel="icon" type="image/png" href="~/images/logo-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

@{
    var currentUser = SignInManager.IsSignedIn(User)
        ? await UserManager.GetUserAsync(User)
        : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "Admin";
    var initials = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "A";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string NavClass(string ctrl, string? action = null)
    {
        bool match = currentController == ctrl && (action == null || currentAction == action);
        return match ? "adm-nav-link active" : "adm-nav-link";
    }
}

<div class="adm-shell" id="admShell">

    <!-- ══ SIDEBAR ══ -->
    <aside class="adm-sidebar" id="admSidebar">

        <a class="adm-sidebar-brand" asp-controller="Home" asp-action="Index">
            <div class="adm-brand-icon">🔧</div>
            <div>
                <span class="adm-brand-text">FixIt</span>
                <span class="adm-brand-sub">Admin Panel</span>
            </div>
        </a>

        <nav class="adm-nav">
            <span class="adm-nav-section-label">Overview</span>
            <a class="@NavClass("Admin","Dashboard")" asp-controller="Admin" asp-action="Dashboard">
                <span class="adm-nav-icon">📊</span>
                <span class="adm-nav-label">Dashboard</span>
            </a>

            <span class="adm-nav-section-label">Management</span>
            <a class="@NavClass("Issue")" asp-controller="Issue" asp-action="AdminIndex">
                <span class="adm-nav-icon">📋</span>
                <span class="adm-nav-label">Issues</span>
            </a>
            <a class="@NavClass("Schedule")" asp-controller="Schedule" asp-action="Index">
                <span class="adm-nav-icon">📅</span>
                <span class="adm-nav-label">Schedule</span>
            </a>

            <span class="adm-nav-section-label">Analytics</span>
            <a class="@NavClass("Report")" asp-controller="Report" asp-action="Index">
                <span class="adm-nav-icon">📈</span>
                <span class="adm-nav-label">Reports</span>
            </a>
            <a class="@NavClass("Rating")" asp-controller="Rating" asp-action="Index">
                <span class="adm-nav-icon">⭐</span>
                <span class="adm-nav-label">Ratings</span>
            </a>
        </nav>

        <div class="adm-sidebar-footer">
            <button class="adm-collapse-btn" id="sidebarCollapseBtn" title="Toggle sidebar">
                <span class="adm-collapse-icon">◀</span>
                <span class="adm-collapse-label">Collapse</span>
            </button>
            <form asp-controller="Account" asp-action="Logout" method="post" style="margin:0">
                @Html.AntiForgeryToken()
                <button type="submit" class="adm-logout-btn">
                    <span class="adm-nav-icon">🚪</span>
                    <span class="adm-logout-label">Logout</span>
                </button>
            </form>
        </div>

    </aside>

    <!-- ══ MAIN ══ -->
    <div class="adm-main">

        <!-- Top Bar -->
        <header class="adm-topbar">
            <div class="adm-topbar-left">
                <div>
                    <div class="adm-topbar-title">Admin Dashboard</div>
                    <div class="adm-breadcrumb">
                        <span>FixIt</span>
                        <span class="adm-breadcrumb-sep">›</span>
                        <span>@(ViewData["Title"] ?? "Dashboard")</span>
                    </div>
                </div>
            </div>
            <div class="adm-topbar-right">
                <button class="adm-theme-toggle" id="admThemeToggle" title="Toggle dark mode">🌙</button>
                <div class="adm-user-pill">
                    <div class="adm-avatar">@initials</div>
                    <div>
                        <div class="adm-user-name">@displayName</div>
                        <div class="adm-user-role">Admin</div>
                    </div>
                </div>
            </div>
        </header>

        <!-- Page Content -->
        <main class="adm-content" role="main">
            @RenderBody()
        </main>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    const shell    = document.getElementById('admShell');
    const sidebar  = document.getElementById('admSidebar');
    const colBtn   = document.getElementById('sidebarCollapseBtn');
    const themeBtn = document.getElementById('admThemeToggle');
    const html     = document.documentElement;

    // Persist sidebar state
    const collapsed = localStorage.getItem('admSidebarCollapsed') === 'true';
    if (collapsed) { sidebar.classList.add('collapsed'); shell.classList.add('sidebar-collapsed'); }

    colBtn?.addEventListener('click', () => {
        const isNowCollapsed = sidebar.classList.toggle('collapsed');
        shell.classList.toggle('sidebar-collapsed', isNowCollapsed);
        localStorage.setItem('admSidebarCollapsed', isNowCollapsed);
    });

    // Theme toggle
    const savedTheme = localStorage.getItem('admTheme') || 'light';
    html.setAttribute('data-adm-theme', savedTheme);
    themeBtn.textContent = savedTheme === 'dark' ? '☀️' : '🌙';

    themeBtn?.addEventListener('click', () => {
        const current = html.getAttribute('data-adm-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-adm-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀️' : '🌙';
        localStorage.setItem('admTheme', next);
    });
})();
</script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
