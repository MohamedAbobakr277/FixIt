@using Microsoft.AspNetCore.Identity
@using FixIt.DAL.Entities
@using FixIt.BLL.Interfaces
@using FixIt.Common.Constants
@inject SignInManager<ApplicationUser> SignInManager
@inject UserManager<ApplicationUser> UserManager
@inject INotificationService NotificationService
<!DOCTYPE html>
<html lang="en" data-adm-theme="light">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="description" content="FixIt Admin — Manage and oversee community issue reports." />
    <title>@ViewData["Title"] - FixIt Admin</title>
    <link rel="icon" type="image/png" href="~/images/logo-icon.png" asp-append-version="true" />
    <link rel="stylesheet" href="~/lib/bootstrap/dist/css/bootstrap.min.css" />
    <link rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.3/font/bootstrap-icons.min.css">
    <link rel="stylesheet" href="~/css/admin.css" asp-append-version="true" />
    @RenderSection("Styles", required: false)
</head>
<body>

@{
    var currentUser = SignInManager.IsSignedIn(User)
        ? await UserManager.GetUserAsync(User)
        : null;
    var displayName = currentUser?.FullName ?? User.Identity?.Name ?? "Admin";
    var initials = displayName.Length > 0 ? displayName[0].ToString().ToUpper() : "A";

    var currentController = ViewContext.RouteData.Values["controller"]?.ToString();
    var currentAction = ViewContext.RouteData.Values["action"]?.ToString();

    string NavClass(string ctrl, string? action = null)
    {
        bool match = currentController == ctrl && (action == null || currentAction == action);
        return match ? "adm-nav-link active" : "adm-nav-link";
    }
}
@{
    var unreadCount = await NotificationService.GetAdminUnreadCountAsync();
    var adminNotifications = await NotificationService.GetAdminNotificationsAsync(5);
}

<div class="adm-shell" id="admShell">

    <!-- ══ TOP BAR ══ -->
    <header class="adm-topbar">
        <div class="adm-topbar-left">
            <a class="adm-topbar-brand" asp-controller="Home" asp-action="Index">
                <img src="~/images/logo-icon.png" alt="FixIt Logo" class="adm-brand-logo" />
                <span class="adm-brand-text">FixIt</span>
            </a>
        </div>
            
        <nav class="adm-nav-horizontal">
            <a class="@NavClass("Admin","Dashboard")" asp-controller="Admin" asp-action="Dashboard">
                <span class="adm-nav-label">Overview</span>
            </a>
            <a class="@NavClass("Issue")" asp-controller="Issue" asp-action="AdminIndex">
                <span class="adm-nav-label">Issues</span>
            </a>
            <a class="@NavClass("Admin", "Schedule")" asp-controller="Admin" asp-action="Schedule">
                <span class="adm-nav-label">Schedule</span>
            </a>
            <a class="@NavClass("Admin", "Reports")" asp-controller="Admin" asp-action="Reports">
                <span class="adm-nav-label">Reports</span>
            </a>
            <a class="@NavClass("Admin", "Ratings")" asp-controller="Admin" asp-action="Ratings">
                <span class="adm-nav-label">Ratings</span>
            </a>
        </nav>
        <div class="adm-topbar-right">
            <button class="adm-icon-btn" id="admThemeToggle" title="Toggle Theme">🌙</button>

            <div class="dropdown">
                <button class="adm-icon-btn" title="Notifications" style="position: relative;" data-bs-toggle="dropdown" aria-expanded="false">
                    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round"><path d="M18 8A6 6 0 0 0 6 8c0 7-3 9-3 9h18s-3-2-3-9"></path><path d="M13.73 21a2 2 0 0 1-3.46 0"></path></svg>
                    @if(unreadCount > 0)
                    {
                        <span style="position: absolute; top: 8px; right: 8px; width: 6px; height: 6px; background: #ef4444; border-radius: 50%; border: 1px solid #fff;"></span>
                    }
                </button>
                <div class="dropdown-menu dropdown-menu-end shadow-sm adm-dropdown" style="margin-top: 10px; width: 300px; padding: 0;">
                    <div class="adm-dropdown-header" style="border-bottom: 1px solid var(--adm-border); padding: 12px 16px;">
                        <div class="adm-dropdown-name" style="font-size: 14px;">Notifications</div>
                    </div>
                    <div style="max-height: 300px; overflow-y: auto;">
                        @if (!adminNotifications.Any())
                        {
                            <div style="padding: 16px; text-align: center; color: var(--adm-text-light); font-size: 13px;">No new notifications</div>
                        }
                        else
                        {
                            foreach (var notif in adminNotifications)
                            {
                                var fixedUrl = notif.RelatedEntityUrl?.Replace("/Admin/IssueDetails", "/Issue/AdminDetails");
                                <a class="dropdown-item" href="/api/Notification/admin/read-and-redirect/@notif.Id?url=@Uri.EscapeDataString(fixedUrl ?? "/Admin/Dashboard")" style="padding: 12px 16px; border-bottom: 1px solid var(--adm-border); white-space: normal; @(notif.IsRead ? "opacity: 0.7;" : "background: rgba(14,165,233,0.05);")">
                                    <div style="font-weight: 600; font-size: 13px; color: var(--adm-text); margin-bottom: 4px;">@notif.Title</div>
                                    <div style="font-size: 12px; color: var(--adm-text-light);">@notif.Message</div>
                                    <div style="font-size: 11px; color: var(--adm-text-light); margin-top: 6px;">@notif.CreatedAt.ToString("MMM dd, HH:mm")</div>
                                </a>
                            }
                        }
                    </div>
                </div>
            </div>
            <div class="dropdown" style="margin-left: 4px;">
                @if (!string.IsNullOrWhiteSpace(currentUser?.ProfileImageUrl))
                {
                    <img src="@currentUser.ProfileImageUrl" alt="Profile" data-bs-toggle="dropdown" aria-expanded="false" style="width: 34px; height: 34px; border-radius: 50%; object-fit: cover; cursor: pointer; border: 1px solid var(--adm-border);" title="@displayName" onerror="this.classList.add('d-none'); this.nextElementSibling.classList.remove('d-none');" />
                    <div class="adm-avatar d-none" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;" title="@displayName">@initials</div>
                }
                else
                {
                    <div class="adm-avatar" data-bs-toggle="dropdown" aria-expanded="false" style="cursor: pointer;" title="@displayName">@initials</div>
                }
                <ul class="dropdown-menu dropdown-menu-end shadow-sm adm-dropdown" style="margin-top: 10px;">
                    <li class="dropdown-header">
                        <div class="dropdown-user-full" style="font-weight: 600; color: var(--adm-text);">@displayName</div>
                        <div class="dropdown-user-role text-muted" style="font-size: 12px;">Administrator</div>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <a class="dropdown-item" asp-controller="Admin" asp-action="Profile" style="font-size: 14px; display: flex; align-items: center;">
                            <i class="bi bi-person me-2"></i> My Profile
                        </a>
                    </li>
                    <li>
                        <a class="dropdown-item" asp-controller="Admin" asp-action="Settings" style="font-size: 14px; display: flex; align-items: center;">
                            <i class="bi bi-gear me-2"></i> Settings
                        </a>
                    </li>
                    <li><hr class="dropdown-divider"></li>
                    <li>
                        <form asp-controller="Account" asp-action="Logout" method="post" class="m-0">
                            @Html.AntiForgeryToken()
                            <button type="submit" class="dropdown-item text-danger" style="font-size: 14px; display: flex; align-items: center;">
                                <i class="bi bi-box-arrow-right me-2"></i> Log Out
                            </button>
                        </form>
                    </li>
                </ul>
            </div>
        </div>
    </header>

    <!-- ══ MAIN ══ -->
    <div class="adm-main">

        <!-- Page Content -->
        <main class="adm-content" role="main">
            @RenderBody()
        </main>

    </div>
</div>

<script src="~/lib/jquery/dist/jquery.min.js"></script>
<script src="~/lib/bootstrap/dist/js/bootstrap.bundle.min.js"></script>
<script>
(function () {
    const shell    = document.getElementById('admShell');
    const sidebar  = document.getElementById('admSidebar');
    const colBtn   = document.getElementById('sidebarCollapseBtn');
    const themeBtn = document.getElementById('admThemeToggle');
    const html     = document.documentElement;

    // Persist sidebar state
    const collapsed = localStorage.getItem('admSidebarCollapsed') === 'true';
    if (collapsed) { sidebar.classList.add('collapsed'); shell.classList.add('sidebar-collapsed'); }

    colBtn?.addEventListener('click', () => {
        const isNowCollapsed = sidebar.classList.toggle('collapsed');
        shell.classList.toggle('sidebar-collapsed', isNowCollapsed);
        localStorage.setItem('admSidebarCollapsed', isNowCollapsed);
    });

    // Theme toggle
    const savedTheme = localStorage.getItem('admTheme') || 'light';
    html.setAttribute('data-adm-theme', savedTheme);
    themeBtn.textContent = savedTheme === 'dark' ? '☀️' : '🌙';

    themeBtn?.addEventListener('click', () => {
        const current = html.getAttribute('data-adm-theme');
        const next = current === 'dark' ? 'light' : 'dark';
        html.setAttribute('data-adm-theme', next);
        themeBtn.textContent = next === 'dark' ? '☀️' : '🌙';
        localStorage.setItem('admTheme', next);
    });
})();
</script>
@await RenderSectionAsync("Scripts", required: false)

</body>
</html>
