@{
    ViewData["Title"] = "Reset Link Sent";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">
        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <div class="text-center mb-4">
            <div class="mb-3" style="font-size: 3rem; color: var(--success);">
                <i class="bi bi-envelope-check"></i>
            </div>
            <h1 class="auth-title">Check Your Email</h1>
            <p class="auth-subtitle">
                If an account exists for that email, we've sent a link to reset your password.
            </p>
        </div>

        <p class="text-center text-muted mb-4">
            Please check your inbox (and spam folder) for further instructions.
        </p>

        <a asp-action="Login" class="auth-submit text-center" style="text-decoration: none;">
            Return to Login
        </a>
    </div>
</div>
