@model IEnumerable<FixIt.Common.DTOs.LoginActivityDto>
@{
    ViewData["Title"] = "Login Activity";
}

<div class="page-wrapper">
    <div class="section-container" style="max-width: 800px;">
        <div class="mb-5 d-flex align-items-center justify-content-between">
            <div>
                <h1 class="section-title mb-2">Login Activity</h1>
                <p class="text-muted">Review your recent login sessions and active devices.</p>
            </div>
            <a asp-controller="Citizen" asp-action="Settings" class="btn-outline-fixit btn-sm">
                <i class="bi bi-gear"></i> Back to Settings
            </a>
        </div>

        <div class="card-fixit p-0 overflow-hidden">
            <div class="table-responsive">
                <table class="table table-hover mb-0">
                    <thead class="bg-surface-2">
                        <tr>
                            <th class="ps-4 py-3 border-0 small text-uppercase fw-800 text-muted" style="letter-spacing: 0.05em;">Device & Location</th>
                            <th class="py-3 border-0 small text-uppercase fw-800 text-muted" style="letter-spacing: 0.05em;">IP Address</th>
                            <th class="py-3 border-0 small text-uppercase fw-800 text-muted" style="letter-spacing: 0.05em;">Time</th>
                            <th class="pe-4 py-3 border-0 small text-uppercase fw-800 text-muted text-end" style="letter-spacing: 0.05em;">Status</th>
                        </tr>
                    </thead>
                    <tbody>
                        @foreach (var activity in Model)
                        {
                            <tr>
                                <td class="ps-4 py-4">
                                    <div class="d-flex align-items-center gap-3">
                                        <div class="activity-icon @(activity.Device.Contains("iPhone") ? "mobile" : "desktop")">
                                            <i class="bi bi-@(activity.Device.Contains("iPhone") ? "smartphone" : "laptop")"></i>
                                        </div>
                                        <div>
                                            <div class="fw-700 text-heading">@activity.Device</div>
                                            <div class="small text-muted"><i class="bi bi-geo-alt me-1"></i> @activity.Location</div>
                                        </div>
                                    </div>
                                </td>
                                <td class="py-4 small font-monospace text-muted">@activity.IpAddress</td>
                                <td class="py-4">
                                    <div class="small fw-600">@activity.Timestamp.ToString("MMM d, yyyy")</div>
                                    <div class="small text-muted">@activity.Timestamp.ToString("h:mm tt")</div>
                                </td>
                                <td class="pe-4 py-4 text-end">
                                    @if (activity.IsCurrentSession)
                                    {
                                        <span class="badge bg-success-fixit">Current Session</span>
                                    }
                                    else
                                    {
                                        <span class="badge bg-light text-muted border">Active Session</span>
                                    }
                                </td>
                            </tr>
                        }
                    </tbody>
                </table>
            </div>
        </div>

        <div class="mt-4 p-4 border rounded-3 bg-surface-2 d-flex align-items-center gap-3">
            <div class="icon-circle bg-warning-light text-warning" style="width: 48px; height: 48px; display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 20px;">
                <i class="bi bi-exclamation-triangle"></i>
            </div>
            <div>
                <h6 class="mb-1 fw-700">Notice anything suspicious?</h6>
                <p class="small text-muted mb-0">If you don't recognize a device or location, we recommend changing your password immediately.</p>
            </div>
            <a asp-action="ChangePassword" class="btn-primary-fixit btn-sm ms-auto">Change Password</a>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .activity-icon { width: 42px; height: 42px; border-radius: 12px; display: flex; align-items: center; justify-content: center; font-size: 20px; flex-shrink: 0; }
        .activity-icon.desktop { background: var(--primary-glow); color: var(--primary); }
        .activity-icon.mobile { background: rgba(168, 85, 247, 0.1); color: #a855f7; }
        .fw-800 { font-weight: 800; }
        .fw-700 { font-weight: 700; }
        .fw-600 { font-weight: 600; }
        .bg-warning-light { background: rgba(245, 158, 11, 0.1); }
        .bg-success-fixit { background-color: #22c55e !important; color: white !important; }
        .badge { font-size: 10px; text-transform: uppercase; letter-spacing: 0.05em; padding: 5px 10px; border-radius: 6px; }
    </style>
}
