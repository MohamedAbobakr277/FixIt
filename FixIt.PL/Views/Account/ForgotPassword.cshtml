@model FixIt.Common.DTOs.ForgotPasswordDto
@{
    ViewData["Title"] = "Forgot Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">
        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Forgot Password</h1>
        <p class="auth-subtitle">Enter your email to receive a password reset link</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert-error-auth"></div>
        }

        <form asp-action="ForgotPassword" method="post" id="forgotPasswordForm" novalidate>
            @Html.AntiForgeryToken()

            <div class="form-floating mb-4">
                <input asp-for="Email" 
                       type="email" 
                       class="form-control" 
                       id="ForgotEmail" 
                       placeholder="you@example.com" 
                       autocomplete="email" />
                <label for="ForgotEmail">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <button type="submit" class="auth-submit" id="submitBtn">
                Send Reset Link →
            </button>
        </form>

        <p class="auth-footer">
            Remember your password?
            <a asp-action="Login">Back to Sign In</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('forgotPasswordForm').addEventListener('submit', function () {
            var btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.textContent = 'Sending…';
        });
    </script>
}
