@model TwoFactorSetupDto
@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
}

<div class="page-wrapper">
    <div class="section-container d-flex justify-content-center align-items-center" style="min-height: calc(100vh - 120px);">
        <div class="card-fixit shadow-lg p-5" style="max-width: 500px; width: 100%;">
            <div class="text-center mb-5">
                <div class="feature-icon mx-auto mb-4" style="width: 64px; height: 64px; font-size: 28px;">
                    <i class="bi bi-shield-check"></i>
                </div>
                <h2 class="section-title mb-2">Secure Your Account</h2>
                <p class="text-muted">Enhance your account security with Two-Factor Authentication.</p>
            </div>

            <div class="setup-steps">
                <div class="mb-4">
                    <p class="small fw-bold text-uppercase tracking-wider mb-3">1. Scan QR Code</p>
                    <div class="text-center p-3 border rounded-3 bg-white mb-3 shadow-sm">
                        <img src="@Model.QrCodeImageUrl" class="img-fluid" alt="QR Code" style="max-height: 180px;" />
                    </div>
                    <p class="small text-muted text-center">Scan this with Google Authenticator or Microsoft Authenticator.</p>
                </div>

                <div class="mb-4">
                    <p class="small fw-bold text-uppercase tracking-wider mb-2">2. Enter Key Manually (Optional)</p>
                    <div class="p-2 px-3 bg-surface-2 rounded border small font-monospace text-center">
                        @Model.ManualEntryKey
                    </div>
                </div>

                <form asp-action="Setup2FA" method="post" class="mt-5">
                    <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                    
                    <p class="small fw-bold text-uppercase tracking-wider mb-2">3. Verify Code</p>
                    <div class="mb-4">
                        <input name="code" class="form-control-fixit text-center fs-4 fw-bold" style="letter-spacing: 0.5em;" 
                               placeholder="000000" maxlength="6" required autocomplete="off" />
                    </div>

                    <div class="d-grid gap-3">
                        <button type="submit" class="btn-primary-fixit justify-content-center w-100 py-3">
                            Enable 2FA Now
                        </button>
                        <a asp-controller="Home" asp-action="Index" class="btn-outline-fixit justify-content-center w-100">
                            Cancel Setup
                        </a>
                    </div>
                </form>
            </div>
        </div>
    </div>
</div>

@section Styles {
    <style>
        .tracking-wider { letter-spacing: 0.05em; }
        .bg-surface-2 { background-color: var(--bg-surface-2); }
    </style>
}
