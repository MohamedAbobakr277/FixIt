@model TwoFactorSetupDto

@{
    ViewData["Title"] = "Setup Two-Factor Authentication";
}

<div class="container mt-5">
    <div class="row justify-content-center">
        <div class="col-md-6">
            <div class="card shadow-lg border-0 rounded-lg">
                <div class="card-header bg-primary text-white text-center py-4">
                    <h3 class="font-weight-light my-2">Setup 2FA</h3>
                </div>
                <div class="card-body p-5">
                    <p class="text-muted mb-4">
                        Scan the QR code below with your authenticator app (like Google Authenticator or Microsoft Authenticator).
                    </p>

                    <div class="text-center mb-4">
                        <img src="@Model.QrCodeImageUrl" class="img-fluid rounded border p-2" alt="QR Code" style="max-width: 200px;" />
                    </div>

                    <div class="alert alert-info small">
                        <strong>Manual Entry Key:</strong> @Model.ManualEntryKey
                    </div>

                    <form asp-action="Setup2FA" method="post">
                        <div asp-validation-summary="ModelOnly" class="text-danger small mb-3"></div>
                        
                        <div class="form-floating mb-3">
                            <input name="code" class="form-control" placeholder="Enter 6-digit code" required autocomplete="off" />
                            <label for="code">Enter 6-digit verification code</label>
                        </div>

                        <div class="d-grid gap-2">
                            <button type="submit" class="btn btn-primary btn-lg">Verify and Enable</button>
                            <a asp-controller="Home" asp-action="Index" class="btn btn-outline-secondary">Cancel</a>
                        </div>
                    </form>
                </div>
            </div>
        </div>
    </div>
</div>
