@model FixIt.Common.DTOs.ResetPasswordDto
@{
    ViewData["Title"] = "Reset Password";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">
        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Reset Password</h1>
        <p class="auth-subtitle">Create a new secure password for your account</p>

        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="All" class="alert-error-auth"></div>
        }

        <form asp-action="ResetPassword" method="post" id="resetPasswordForm" novalidate>
            @Html.AntiForgeryToken()
            <input asp-for="UserId" type="hidden" />
            <input asp-for="Token" type="hidden" />

            <div class="form-floating mb-3">
                <input asp-for="NewPassword" 
                       type="password" 
                       class="form-control" 
                       id="NewPassword" 
                       placeholder="New Password" 
                       autocomplete="new-password" />
                <label for="NewPassword">New Password</label>
                <span asp-validation-for="NewPassword" class="field-error"></span>
            </div>

            <div class="form-floating mb-4">
                <input asp-for="ConfirmPassword" 
                       type="password" 
                       class="form-control" 
                       id="ConfirmPassword" 
                       placeholder="Confirm Password" 
                       autocomplete="new-password" />
                <label for="ConfirmPassword">Confirm New Password</label>
                <span asp-validation-for="ConfirmPassword" class="field-error"></span>
            </div>

            <button type="submit" class="auth-submit" id="submitBtn">
                Reset Password
            </button>
        </form>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('resetPasswordForm').addEventListener('submit', function () {
            var btn = document.getElementById('submitBtn');
            btn.disabled = true;
            btn.textContent = 'Updating…';
        });
    </script>
}
