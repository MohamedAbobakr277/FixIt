@model FixIt.BLL.DTOs.LoginDto
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to your FixIt account</p>

        <!-- Success message passed from Register redirect -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success-auth">
                <span>✅</span> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation errors (model-level) -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert-error-auth"></div>
        }

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" id="loginForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="LoginEmail"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="LoginEmail">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-1">
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       id="LoginPassword"
                       placeholder="Password"
                       autocomplete="current-password" />
                <label for="LoginPassword">Password</label>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <!-- Remember me -->
            <div class="auth-remember">
                <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                <label for="RememberMe">Keep me signed in for 7 days</label>
            </div>

            <button type="submit" class="auth-submit" id="loginSubmitBtn">
                Sign In →
            </button>
        </form>

        <p class="auth-footer">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Create one for free</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('loginForm').addEventListener('submit', function () {
            var btn = document.getElementById('loginSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Signing in…';
        });
    </script>
}
