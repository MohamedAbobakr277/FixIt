@model FixIt.Common.DTOs.LoginDto
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to your FixIt account</p>


        <!-- Validation errors (model-level) -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert-error-auth"></div>
        }

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" id="loginForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="LoginEmail"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="LoginEmail">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-1">
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       id="LoginPassword"
                       placeholder="Password"
                       autocomplete="current-password" />
                <label for="LoginPassword">Password</label>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <!-- Remember me -->
            <div class="auth-remember">
                <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                <label for="RememberMe">Keep me signed in for 7 days</label>
            </div>

            <button type="submit" class="auth-submit" id="loginSubmitBtn">
                Sign In →
            </button>
        </form>
        <div class="text-center mt-2">
            <a asp-action="ForgotPassword" class="text-muted small">Forgot your password?</a>
        </div>

        <div class="my-4 text-center">
            <span class="text-muted">or</span>
        </div>

        <form asp-controller="Account" asp-action="ExternalLogin" asp-route-returnUrl="@returnUrl" method="post">
            <button type="submit" name="provider" value="Google" class="auth-google-btn">
                <svg viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
                    <path fill="none" d="M0 0h48v48H0z"></path>
                </svg>
                Sign in with Google
            </button>
        </form>

        <p class="auth-footer">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Create one for free</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('loginForm').addEventListener('submit', function () {
            var btn = document.getElementById('loginSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Signing in…';
        });
    </script>
}
