@model FixIt.BLL.DTOs.LoginDto
@{
    ViewData["Title"] = "Sign In";
    var returnUrl = ViewData["ReturnUrl"] as string;
}

@section Styles {
<style>
    .auth-page {
        min-height: 100vh;
        background: var(--bg-body);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 16px 60px;
        position: relative;
        overflow: hidden;
    }
    .auth-glow {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
    .auth-glow-1 {
        top: -120px; right: -80px;
        width: 480px; height: 480px;
        background: radial-gradient(circle, rgba(0,188,212,.09) 0%, transparent 70%);
        animation: breathe 8s ease-in-out infinite alternate;
    }
    .auth-glow-2 {
        bottom: -120px; left: -80px;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0,151,167,.06) 0%, transparent 70%);
        animation: breathe 10s ease-in-out infinite alternate-reverse;
    }
    .auth-card {
        background: var(--bg-card);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 44px 48px;
        width: 100%;
        max-width: 460px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        position: relative;
        z-index: 1;
        animation: fadeInPage 0.6s ease forwards;
    }
    .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 28px;
        text-decoration: none;
    }
    .auth-logo-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: var(--radius-md);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
    }
    .auth-logo-text {
        font-family: var(--font-heading);
        font-size: 22px;
        font-weight: 800;
        color: var(--text-heading);
    }
    .auth-title {
        font-family: var(--font-heading);
        font-size: 26px;
        font-weight: 700;
        color: var(--text-heading);
        text-align: center;
        margin: 0 0 6px;
    }
    .auth-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        text-align: center;
        margin-bottom: 32px;
    }
    .form-floating > .form-control {
        background: var(--bg-surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-body);
        font-size: 14px;
        transition: var(--transition);
    }
    .form-floating > .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
        background: var(--bg-surface);
    }
    .form-floating > label { color: var(--text-muted); font-size: 13.5px; }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: var(--primary);
    }
    .auth-submit {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff;
        border: none;
        border-radius: var(--radius-full);
        font-size: 15px;
        font-weight: 600;
        font-family: var(--font-body);
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 4px 16px rgba(0,151,167,0.28);
        margin-top: 8px;
        position: relative;
        overflow: hidden;
    }
    .auth-submit::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
        transition: left 0.5s ease;
    }
    .auth-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,151,167,0.38); }
    .auth-submit:hover::before { left: 100%; }
    .auth-remember {
        display: flex;
        align-items: center;
        gap: 10px;
        margin: 16px 0;
    }
    .auth-remember input[type="checkbox"] {
        width: 17px; height: 17px;
        accent-color: var(--primary);
        cursor: pointer;
        border-radius: 4px;
        flex-shrink: 0;
    }
    .auth-remember label {
        font-size: 13.5px;
        color: var(--text-muted);
        cursor: pointer;
        user-select: none;
    }
    .auth-footer {
        text-align: center;
        margin-top: 24px;
        font-size: 13.5px;
        color: var(--text-muted);
    }
    .auth-footer a { color: var(--primary); font-weight: 600; }
    .auth-footer a:hover { color: var(--primary-dark); }
    .field-error { font-size: 12px; color: #dc2626; margin-top: 4px; display: block; }
    .alert-error-auth {
        background: rgba(239,68,68,.07);
        border: 1.5px solid rgba(239,68,68,.2);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #dc2626;
    }
    .alert-error-auth ul { margin: 0; padding-left: 18px; }
    .alert-success-auth {
        background: rgba(16,185,129,.08);
        border: 1.5px solid rgba(16,185,129,.25);
        color: #059669;
        border-radius: var(--radius-md);
        padding: 12px 16px;
        font-size: 13.5px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    @@media(max-width: 500px) {
        .auth-card { padding: 32px 24px; }
    }
</style>
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <div class="auth-logo-icon">🔧</div>
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Welcome back</h1>
        <p class="auth-subtitle">Sign in to your FixIt account</p>

        <!-- Success message passed from Register redirect -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success-auth">
                <span>✅</span> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation errors (model-level) -->
        @if (!ViewData.ModelState.IsValid)
        {
            <div asp-validation-summary="ModelOnly" class="alert-error-auth"></div>
        }

        <form asp-action="Login" asp-route-returnUrl="@returnUrl" method="post" id="loginForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="LoginEmail"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="LoginEmail">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password -->
            <div class="form-floating mb-1">
                <input asp-for="Password"
                       type="password"
                       class="form-control"
                       id="LoginPassword"
                       placeholder="Password"
                       autocomplete="current-password" />
                <label for="LoginPassword">Password</label>
                <span asp-validation-for="Password" class="field-error"></span>
            </div>

            <!-- Remember me -->
            <div class="auth-remember">
                <input asp-for="RememberMe" type="checkbox" id="RememberMe" />
                <label for="RememberMe">Keep me signed in for 7 days</label>
            </div>

            <button type="submit" class="auth-submit" id="loginSubmitBtn">
                Sign In →
            </button>
        </form>

        <p class="auth-footer">
            Don't have an account?
            <a asp-controller="Account" asp-action="Register">Create one for free</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        document.getElementById('loginForm').addEventListener('submit', function () {
            var btn = document.getElementById('loginSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Signing in…';
        });
    </script>
}
