@model FixIt.Common.DTOs.ChangePasswordDto
@{
    ViewData["Title"] = "Change Password";
}

<div class="page-wrapper d-flex align-items-center justify-content-center" style="min-height: 80vh;">
    <div class="card-fixit p-5" style="width: 100%; max-width: 500px;">
        <div class="text-center mb-5">
            <div class="icon-circle mb-4 mx-auto" style="width: 64px; height: 64px; background: var(--primary-glow); color: var(--primary); display: flex; align-items: center; justify-content: center; border-radius: 50%; font-size: 28px;">
                <i class="bi bi-key"></i>
            </div>
            <h2 class="fw-800 mb-2">Change Password</h2>
            <p class="text-muted small">Choose a strong, unique password to protect your account.</p>
        </div>

        <form asp-action="ChangePassword" method="post" class="auth-form">
            <div asp-validation-summary="ModelOnly" class="text-danger small mb-4"></div>

            <div class="mb-4">
                <label asp-for="OldPassword" class="form-label-fixit">Current Password</label>
                <div class="input-group-fixit">
                    <span class="input-icon"><i class="bi bi-shield-lock"></i></span>
                    <input asp-for="OldPassword" class="form-control-fixit" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="OldPassword" class="text-danger small"></span>
            </div>

            <div class="mb-4">
                <label asp-for="NewPassword" class="form-label-fixit">New Password</label>
                <div class="input-group-fixit">
                    <span class="input-icon"><i class="bi bi-lock"></i></span>
                    <input asp-for="NewPassword" class="form-control-fixit" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="NewPassword" class="text-danger small"></span>
            </div>

            <div class="mb-5">
                <label asp-for="ConfirmPassword" class="form-label-fixit">Confirm New Password</label>
                <div class="input-group-fixit">
                    <span class="input-icon"><i class="bi bi-check2-all"></i></span>
                    <input asp-for="ConfirmPassword" class="form-control-fixit" placeholder="••••••••" required />
                </div>
                <span asp-validation-for="ConfirmPassword" class="text-danger small"></span>
            </div>

            <button type="submit" class="btn-primary-fixit w-100 py-3 mb-4">
                Update Password
            </button>

            <div class="text-center">
                <a asp-controller="Citizen" asp-action="Settings" class="text-decoration-none small text-muted hover-primary">
                    <i class="bi bi-arrow-left me-1"></i> Back to Settings
                </a>
            </div>
        </form>
    </div>
</div>

@section Styles {
    <style>
        .input-group-fixit { position: relative; display: flex; align-items: center; }
        .input-icon { position: absolute; left: 16px; color: var(--text-light); z-index: 10; font-size: 18px; }
        .form-control-fixit { padding-left: 48px !important; }
        .fw-800 { font-weight: 800; }
        .hover-primary:hover { color: var(--primary) !important; }
    </style>
}
