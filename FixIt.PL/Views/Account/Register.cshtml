@model FixIt.BLL.DTOs.RegisterDto
@{
    ViewData["Title"] = "Create Account";
}

@section Styles {
<style>
    .auth-page {
        min-height: 100vh;
        background: var(--bg-body);
        display: flex;
        align-items: center;
        justify-content: center;
        padding: 100px 16px 60px;
        position: relative;
        overflow: hidden;
    }
    .auth-glow {
        position: absolute;
        border-radius: 50%;
        pointer-events: none;
    }
    .auth-glow-1 {
        top: -120px; right: -80px;
        width: 480px; height: 480px;
        background: radial-gradient(circle, rgba(0,188,212,.09) 0%, transparent 70%);
        animation: breathe 8s ease-in-out infinite alternate;
    }
    .auth-glow-2 {
        bottom: -120px; left: -80px;
        width: 400px; height: 400px;
        background: radial-gradient(circle, rgba(0,151,167,.06) 0%, transparent 70%);
        animation: breathe 10s ease-in-out infinite alternate-reverse;
    }
    .auth-card {
        background: var(--bg-card);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-xl);
        padding: 44px 48px;
        width: 100%;
        max-width: 520px;
        box-shadow: 0 8px 40px rgba(0,0,0,0.08);
        position: relative;
        z-index: 1;
        animation: fadeInPage 0.6s ease forwards;
    }
    .auth-logo {
        display: flex;
        align-items: center;
        justify-content: center;
        gap: 10px;
        margin-bottom: 28px;
        text-decoration: none;
    }
    .auth-logo-icon {
        width: 40px; height: 40px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        border-radius: var(--radius-md);
        display: flex; align-items: center; justify-content: center;
        font-size: 20px;
    }
    .auth-logo-text {
        font-family: var(--font-heading);
        font-size: 22px;
        font-weight: 800;
        color: var(--text-heading);
    }
    .auth-title {
        font-family: var(--font-heading);
        font-size: 26px;
        font-weight: 700;
        color: var(--text-heading);
        text-align: center;
        margin: 0 0 6px;
    }
    .auth-subtitle {
        font-size: 14px;
        color: var(--text-muted);
        text-align: center;
        margin-bottom: 32px;
    }
    .auth-divider {
        display: flex;
        align-items: center;
        gap: 12px;
        margin: 20px 0;
        color: var(--text-muted);
        font-size: 12px;
        font-weight: 600;
        text-transform: uppercase;
        letter-spacing: .06em;
    }
    .auth-divider::before, .auth-divider::after {
        content: '';
        flex: 1;
        height: 1px;
        background: var(--border);
    }
    .auth-row { display: grid; grid-template-columns: 1fr 1fr; gap: 14px; }
    @@media(max-width: 500px) {
        .auth-card { padding: 32px 24px; }
        .auth-row { grid-template-columns: 1fr; }
    }
    .form-floating > .form-control {
        background: var(--bg-surface);
        border: 1.5px solid var(--border);
        border-radius: var(--radius-sm);
        color: var(--text-body);
        font-size: 14px;
        transition: var(--transition);
    }
    .form-floating > .form-control:focus {
        border-color: var(--primary);
        box-shadow: 0 0 0 3px var(--primary-glow);
        background: var(--bg-surface);
    }
    .form-floating > label { color: var(--text-muted); font-size: 13.5px; }
    .form-floating > .form-control:focus ~ label,
    .form-floating > .form-control:not(:placeholder-shown) ~ label {
        color: var(--primary);
    }
    .auth-submit {
        width: 100%;
        padding: 14px;
        background: linear-gradient(135deg, var(--primary), var(--primary-light));
        color: #fff;
        border: none;
        border-radius: var(--radius-full);
        font-size: 15px;
        font-weight: 600;
        font-family: var(--font-body);
        cursor: pointer;
        transition: var(--transition);
        box-shadow: 0 4px 16px rgba(0,151,167,0.28);
        margin-top: 8px;
        position: relative;
        overflow: hidden;
    }
    .auth-submit::before {
        content: '';
        position: absolute;
        top: 0; left: -100%;
        width: 100%; height: 100%;
        background: linear-gradient(90deg, transparent, rgba(255,255,255,0.18), transparent);
        transition: left 0.5s ease;
    }
    .auth-submit:hover { transform: translateY(-2px); box-shadow: 0 8px 24px rgba(0,151,167,0.38); }
    .auth-submit:hover::before { left: 100%; }
    .auth-footer {
        text-align: center;
        margin-top: 24px;
        font-size: 13.5px;
        color: var(--text-muted);
    }
    .auth-footer a { color: var(--primary); font-weight: 600; }
    .auth-footer a:hover { color: var(--primary-dark); }
    .alert-success-auth {
        background: rgba(16,185,129,.08);
        border: 1.5px solid rgba(16,185,129,.25);
        color: #059669;
        border-radius: var(--radius-md);
        padding: 12px 16px;
        font-size: 13.5px;
        margin-bottom: 20px;
        display: flex;
        align-items: center;
        gap: 8px;
    }
    .field-error { font-size: 12px; color: #dc2626; margin-top: 4px; }
    .validation-summary-errors {
        background: rgba(239,68,68,.07);
        border: 1.5px solid rgba(239,68,68,.2);
        border-radius: var(--radius-md);
        padding: 12px 16px;
        margin-bottom: 20px;
        font-size: 13px;
        color: #dc2626;
    }
    .validation-summary-errors ul { margin: 0; padding-left: 18px; }
    .optional-badge {
        font-size: 10px;
        font-weight: 600;
        background: var(--bg-surface-2);
        color: var(--text-muted);
        padding: 2px 7px;
        border-radius: var(--radius-full);
        margin-left: 4px;
        vertical-align: middle;
    }
    .section-label-sm {
        font-size: 11px;
        font-weight: 700;
        text-transform: uppercase;
        letter-spacing: .08em;
        color: var(--text-muted);
        margin: 20px 0 12px;
    }
</style>
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <div class="auth-logo-icon">🔧</div>
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Join FixIt and start reporting community issues</p>

        <!-- Success message after redirect -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success-auth">
                <span>✅</span> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation summary (server-side global errors) -->
        <div asp-validation-summary="All" class="validation-summary-errors" style="display:none"></div>
        @{
            var hasSummaryErrors = !ViewData.ModelState.IsValid &&
                                   ViewData.ModelState.ContainsKey(string.Empty) &&
                                   ViewData.ModelState[string.Empty]!.Errors.Count > 0;
        }
        @if (hasSummaryErrors)
        {
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        }

        <form asp-action="Register" method="post" id="registerForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Required info -->
            <div class="section-label-sm">Account Information</div>

            <!-- Full Name -->
            <div class="form-floating mb-3">
                <input asp-for="FullName"
                       class="form-control"
                       id="FullName"
                       placeholder="Jane Smith"
                       autocomplete="name" />
                <label for="FullName">Full Name</label>
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="Email"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="Email">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password row -->
            <div class="auth-row mb-3">
                <div>
                    <div class="form-floating">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="Password"
                               placeholder="Password"
                               autocomplete="new-password" />
                        <label for="Password">Password</label>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div>
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               id="ConfirmPassword"
                               placeholder="Confirm Password"
                               autocomplete="new-password" />
                        <label for="ConfirmPassword">Confirm Password</label>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <!-- Optional info -->
            <div class="section-label-sm">
                Optional Info <span class="optional-badge">Optional</span>
            </div>

            <div class="auth-row mb-3">
                <div class="form-floating">
                    <input asp-for="PhoneNumber"
                           type="tel"
                           class="form-control"
                           id="PhoneNumber"
                           placeholder="+1 234 567 8900"
                           autocomplete="tel" />
                    <label for="PhoneNumber">Phone Number</label>
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Address"
                           class="form-control"
                           id="Address"
                           placeholder="123 Main St"
                           autocomplete="street-address" />
                    <label for="Address">Address</label>
                </div>
            </div>

            <button type="submit" class="auth-submit" id="registerSubmitBtn">
                Create Account →
            </button>
        </form>

        <p class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign in here</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Simple loading state on submit
        document.getElementById('registerForm').addEventListener('submit', function () {
            var btn = document.getElementById('registerSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Creating account…';
        });
    </script>
}
