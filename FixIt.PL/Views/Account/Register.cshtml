@model FixIt.Common.DTOs.RegisterDto
@{
    ViewData["Title"] = "Create Account";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card auth-card-wide">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Join FixIt and start reporting community issues</p>

        <!-- Success message after redirect -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success-auth">
                <span>✅</span> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation summary (server-side global errors) -->
        <div asp-validation-summary="All" class="validation-summary-errors" style="display:none"></div>
        @{
            var hasSummaryErrors = !ViewData.ModelState.IsValid &&
                                   ViewData.ModelState.ContainsKey(string.Empty) &&
                                   ViewData.ModelState[string.Empty]!.Errors.Count > 0;
        }
        @if (hasSummaryErrors)
        {
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        }

        <form asp-action="Register" method="post" id="registerForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Required info -->
            <div class="section-label-sm">Account Information</div>

            <!-- Full Name -->
            <div class="form-floating mb-3">
                <input asp-for="FullName"
                       class="form-control"
                       id="FullName"
                       placeholder="Jane Smith"
                       autocomplete="name" />
                <label for="FullName">Full Name</label>
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="Email"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="Email">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password row -->
            <div class="auth-row mb-3">
                <div>
                    <div class="form-floating">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="Password"
                               placeholder="Password"
                               autocomplete="new-password" />
                        <label for="Password">Password</label>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div>
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               id="ConfirmPassword"
                               placeholder="Confirm Password"
                               autocomplete="new-password" />
                        <label for="ConfirmPassword">Confirm Password</label>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <!-- Optional info -->
            <div class="section-label-sm">
                Optional Info <span class="optional-badge">Optional</span>
            </div>

            <div class="auth-row mb-3">
                <div class="form-floating">
                    <input asp-for="PhoneNumber"
                           type="tel"
                           class="form-control"
                           id="PhoneNumber"
                           placeholder="+1 234 567 8900"
                           autocomplete="tel" />
                    <label for="PhoneNumber">Phone Number</label>
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Address"
                           class="form-control"
                           id="Address"
                           placeholder="123 Main St"
                           autocomplete="street-address" />
                    <label for="Address">Address</label>
                </div>
            </div>

            <button type="submit" class="auth-submit" id="registerSubmitBtn">
                Create Account →
            </button>
        </form>

        <p class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign in here</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Simple loading state on submit
        document.getElementById('registerForm').addEventListener('submit', function () {
            var btn = document.getElementById('registerSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Creating account…';
        });
    </script>
}
