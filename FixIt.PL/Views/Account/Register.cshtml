@model FixIt.Common.DTOs.RegisterDto
@{
    ViewData["Title"] = "Create Account";
}

@section Styles {
    <link rel="stylesheet" href="~/css/auth.css" asp-append-version="true" />
}

<div class="auth-page">
    <div class="auth-glow auth-glow-1"></div>
    <div class="auth-glow auth-glow-2"></div>

    <div class="auth-card auth-card-wide">

        <!-- Logo -->
        <a class="auth-logo" asp-controller="Home" asp-action="Index">
            <img src="~/images/logo-icon.png" alt="FixIt Logo" style="width: 40px; height: 40px; border-radius: var(--radius-md); object-fit: contain;" />
            <span class="auth-logo-text">FixIt</span>
        </a>

        <h1 class="auth-title">Create your account</h1>
        <p class="auth-subtitle">Join FixIt and start reporting community issues</p>

        <!-- Success message after redirect -->
        @if (TempData["SuccessMessage"] != null)
        {
            <div class="alert-success-auth">
                <span>✅</span> @TempData["SuccessMessage"]
            </div>
        }

        <!-- Validation summary (server-side global errors) -->
        <div asp-validation-summary="All" class="validation-summary-errors" style="display:none"></div>
        @{
            var hasSummaryErrors = !ViewData.ModelState.IsValid &&
                                   ViewData.ModelState.ContainsKey(string.Empty) &&
                                   ViewData.ModelState[string.Empty]!.Errors.Count > 0;
        }
        @if (hasSummaryErrors)
        {
            <div asp-validation-summary="ModelOnly" class="validation-summary-errors"></div>
        }

        <form asp-action="Register" method="post" id="registerForm" novalidate>
            @Html.AntiForgeryToken()

            <!-- Required info -->
            <div class="section-label-sm">Account Information</div>

            <!-- Full Name -->
            <div class="form-floating mb-3">
                <input asp-for="FullName"
                       class="form-control"
                       id="FullName"
                       placeholder="Jane Smith"
                       autocomplete="name" />
                <label for="FullName">Full Name</label>
                <span asp-validation-for="FullName" class="field-error"></span>
            </div>

            <!-- Role Selection -->
            <div class="mb-3">
                <div class="role-picker-label">Account Type</div>
                <div class="role-picker">
                    <div class="role-card active" id="roleCardCitizen" onclick="selectRole('Citizen')">
                        <div class="role-card-icon">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M20 21v-2a4 4 0 0 0-4-4H8a4 4 0 0 0-4 4v2"/><circle cx="12" cy="7" r="4"/></svg>
                        </div>
                        <div class="role-card-body">
                            <div class="role-card-title">Citizen</div>
                            <div class="role-card-desc">Report & track community issues</div>
                        </div>
                        <div class="role-card-check">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                    </div>
                    <div class="role-card" id="roleCardAdmin" onclick="selectRole('Admin')">
                        <div class="role-card-icon admin">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.8"><path d="M12 22s8-4 8-10V5l-8-3-8 3v7c0 6 8 10 8 10z"/></svg>
                        </div>
                        <div class="role-card-body">
                            <div class="role-card-title">Admin</div>
                            <div class="role-card-desc">Manage & resolve issues city-wide</div>
                        </div>
                        <div class="role-card-check">
                            <svg viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5"><polyline points="20 6 9 17 4 12"/></svg>
                        </div>
                    </div>
                </div>
                <input type="hidden" asp-for="Role" id="RoleHidden" value="Citizen" />
                <span asp-validation-for="Role" class="field-error"></span>
            </div>

            <!-- Email -->
            <div class="form-floating mb-3">
                <input asp-for="Email"
                       type="email"
                       class="form-control"
                       id="Email"
                       placeholder="you@example.com"
                       autocomplete="email" />
                <label for="Email">Email Address</label>
                <span asp-validation-for="Email" class="field-error"></span>
            </div>

            <!-- Password row -->
            <div class="auth-row mb-3">
                <div>
                    <div class="form-floating">
                        <input asp-for="Password"
                               type="password"
                               class="form-control"
                               id="Password"
                               placeholder="Password"
                               autocomplete="new-password" />
                        <label for="Password">Password</label>
                    </div>
                    <span asp-validation-for="Password" class="field-error"></span>
                </div>
                <div>
                    <div class="form-floating">
                        <input asp-for="ConfirmPassword"
                               type="password"
                               class="form-control"
                               id="ConfirmPassword"
                               placeholder="Confirm Password"
                               autocomplete="new-password" />
                        <label for="ConfirmPassword">Confirm Password</label>
                    </div>
                    <span asp-validation-for="ConfirmPassword" class="field-error"></span>
                </div>
            </div>

            <!-- Optional info -->
            <div class="section-label-sm">
                Optional Info <span class="optional-badge">Optional</span>
            </div>

            <div class="auth-row mb-3">
                <div class="form-floating">
                    <input asp-for="PhoneNumber"
                           type="tel"
                           class="form-control"
                           id="PhoneNumber"
                           placeholder="+1 234 567 8900"
                           autocomplete="tel" />
                    <label for="PhoneNumber">Phone Number</label>
                    <span asp-validation-for="PhoneNumber" class="field-error"></span>
                </div>

                <div class="form-floating">
                    <input asp-for="Address"
                           class="form-control"
                           id="Address"
                           placeholder="123 Main St"
                           autocomplete="street-address" />
                    <label for="Address">Address</label>
                </div>
            </div>

            <button type="submit" class="auth-submit" id="registerSubmitBtn">
                Create Account →
            </button>
        </form>

        <div class="my-4 text-center">
            <span class="text-muted">or</span>
        </div>

        <form asp-controller="Account" asp-action="ExternalLogin" method="post">
            <button type="submit" name="provider" value="Google" class="auth-google-btn">
                <svg viewBox="0 0 48 48">
                    <path fill="#EA4335" d="M24 9.5c3.54 0 6.71 1.22 9.21 3.6l6.85-6.85C35.9 2.38 30.47 0 24 0 14.62 0 6.51 5.38 2.56 13.22l7.98 6.19C12.43 13.72 17.74 9.5 24 9.5z"></path>
                    <path fill="#4285F4" d="M46.98 24.55c0-1.57-.15-3.09-.38-4.55H24v9.02h12.94c-.58 2.96-2.26 5.48-4.78 7.18l7.73 6c4.51-4.18 7.09-10.36 7.09-17.65z"></path>
                    <path fill="#FBBC05" d="M10.53 28.59c-.48-1.45-.76-2.99-.76-4.59s.27-3.14.76-4.59l-7.98-6.19C.92 16.46 0 20.12 0 24c0 3.88.92 7.54 2.56 10.78l7.97-6.19z"></path>
                    <path fill="#34A853" d="M24 48c6.48 0 11.93-2.13 15.89-5.81l-7.73-6c-2.15 1.45-4.92 2.3-8.16 2.3-6.26 0-11.57-4.22-13.47-9.91l-7.98 6.19C6.51 42.62 14.62 48 24 48z"></path>
                    <path fill="none" d="M0 0h48v48H0z"></path>
                </svg>
                Sign up with Google
            </button>
        </form>

        <p class="auth-footer">
            Already have an account?
            <a asp-controller="Account" asp-action="Login">Sign in here</a>
        </p>
    </div>
</div>

@section Scripts {
    @await Html.PartialAsync("_ValidationScriptsPartial")
    <script>
        // Simple loading state on submit
        document.getElementById('registerForm').addEventListener('submit', function () {
            var btn = document.getElementById('registerSubmitBtn');
            btn.disabled = true;
            btn.textContent = 'Creating account…';
        });

        function selectRole(role) {
            document.getElementById('RoleHidden').value = role;
            document.getElementById('roleCardCitizen').classList.toggle('active', role === 'Citizen');
            document.getElementById('roleCardAdmin').classList.toggle('active', role === 'Admin');
        }

        // Restore selection if server-side validation fails
        (function () {
            var current = document.getElementById('RoleHidden').value;
            if (current) selectRole(current);
        })();
    </script>
}
